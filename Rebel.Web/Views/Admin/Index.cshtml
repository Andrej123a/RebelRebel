@model Rebel.Web.Models.DashboardViewModel

@{
    ViewData["Title"] = "Control Room";

    var pendingReservationsText =
        Model.PendingReservationsCount.ToString("00");

    var needsAttention =
        Model.TonightPendingReservationsCount +
        Model.TonightUnassignedTablesCount +
        Model.UnavailableProductsCount;
}

<section class="control-room">

    <header class="control-hero">

        <div>
            <div class="control-eyebrow">
                Rebel Rebel backstage operations
            </div>

            <h1 class="control-title">
                Control the<br />
                beautiful chaos.
            </h1>

            <p class="control-copy">
                Events, reservations, food and drinks — everything that keeps
                Rebel Rebel loud, alive and slightly out of control.
            </p>
        </div>

        <div class="control-stamp">
            PRIVATE<br />
            ACCESS
        </div>

    </header>

    <section class="ops-snapshot">

        <a asp-controller="AdminReservations"
           asp-action="Tonight"
           class="ops-card ops-primary">
            <span class="ops-label">
                Tonight
            </span>

            <strong>
                @Model.TonightGuestsCount
            </strong>

            <small>
                guests across @Model.TonightReservationsCount reservations
            </small>
        </a>

        <a asp-controller="AdminReservations"
           asp-action="Index"
           asp-route-status="Pending"
           class="ops-card">
            <span class="ops-label">
                Needs approval
            </span>

            <strong>
                @Model.TonightPendingReservationsCount
            </strong>

            <small>
                pending for tonight
            </small>
        </a>

        <a asp-controller="AdminReservations"
           asp-action="Tonight"
           class="ops-card">
            <span class="ops-label">
                Floor gaps
            </span>

            <strong>
                @Model.TonightUnassignedTablesCount
            </strong>

            <small>
                approved without table
            </small>
        </a>

        <a asp-controller="Product"
           asp-action="Index"
           asp-route-isAvailable="false"
           class="ops-card">
            <span class="ops-label">
                Sold out
            </span>

            <strong>
                @Model.UnavailableProductsCount
            </strong>

            <small>
                unavailable menu items
            </small>
        </a>

        <div class="ops-card ops-alert @(needsAttention > 0 ? "has-work" : "")">
            <span class="ops-label">
                Attention
            </span>

            <strong>
                @needsAttention
            </strong>

            <small>
                live items to handle
            </small>
        </div>

        <a asp-controller="AdminTables"
           asp-action="Index"
           class="ops-card">
            <span class="ops-label">
                Floor capacity
            </span>

            <strong>
                @Model.ActiveTableCapacity
            </strong>

            <small>
                seats across @Model.ActiveTablesCount active tables
            </small>
        </a>

    </section>

    <section class="attention-board">

        <div class="attention-panel">
            <div class="attention-panel-header">
                <div>
                    <span class="attention-kicker">
                        Front door
                    </span>

                    <h2>
                        Pending Requests
                    </h2>
                </div>

                <a asp-controller="AdminReservations"
                   asp-action="Index"
                   asp-route-status="Pending">
                    View all
                </a>
            </div>

            @if (Model.LatestPendingReservations.Any())
            {
                <div class="attention-list">
                    @foreach (var reservation in Model.LatestPendingReservations)
                    {
                        <a asp-controller="AdminReservations"
                           asp-action="Details"
                           asp-route-id="@reservation.Id"
                           class="attention-row">

                            <span class="attention-time">
                                @reservation.ReservationDate.ToString("dd MMM")
                                @reservation.ReservationTime.ToString(@"hh\:mm")
                            </span>

                            <strong>
                                @reservation.FullName
                            </strong>

                            <small>
                                @reservation.NumberOfGuests
                                @(reservation.NumberOfGuests == 1 ? "guest" : "guests")
                            </small>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="attention-empty">
                    No pending reservation requests right now.
                </p>
            }
        </div>

        <div class="attention-panel">
            <div class="attention-panel-header">
                <div>
                    <span class="attention-kicker">
                        Menu board
                    </span>

                    <h2>
                        Unavailable Items
                    </h2>
                </div>

                <a asp-controller="Product"
                   asp-action="Index"
                   asp-route-isAvailable="false">
                    Manage
                </a>
            </div>

            @if (Model.UnavailableProducts.Any())
            {
                <div class="attention-list">
                    @foreach (var product in Model.UnavailableProducts)
                    {
                        <a asp-controller="Product"
                           asp-action="Edit"
                           asp-route-id="@product.Id"
                           class="attention-row">

                            <span class="attention-time">
                                @(product.Category?.Name ?? "Uncategorized")
                            </span>

                            <strong>
                                @product.Name
                            </strong>

                            <small>
                                @product.Price.ToString("0.##") MKD
                            </small>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="attention-empty">
                    Everything on the menu is currently available.
                </p>
            }
        </div>

    </section>

    <div class="chaos-grid">

        <a asp-controller="AdminReservations"
           asp-action="Index"
           asp-route-status="Pending"
           class="control-panel panel-pending">

            <div class="panel-number">
                @pendingReservationsText
            </div>

            <div>
                <span class="panel-kicker">
                    Waiting for a decision
                </span>

                <h2 class="panel-title">
                    Pending Reservations
                </h2>

                <p class="panel-copy">
                    @Model.ReservationsCount total reservation requests
                    currently stored in the system.
                </p>

                <div class="panel-action">
                    Review requests →
                </div>
            </div>

        </a>

        <a asp-controller="AdminEvents"
           asp-action="Index"
           class="control-panel panel-events">

            <div class="panel-small-number">
                @Model.EventsCount
            </div>

            <div>
                <span class="panel-kicker">
                    Live board
                </span>

                <h2 class="panel-title">
                    Events & Nights
                </h2>

                <p class="panel-copy">
                    Create, edit, activate or kill upcoming Rebel nights.
                </p>

                <div class="panel-action">
                    Manage events →
                </div>
            </div>

        </a>

        <a asp-controller="Product"
           asp-action="Index"
           class="control-panel panel-menu">

            <div class="panel-small-number">
                @Model.ProductsCount
            </div>

            <div>
                <span class="panel-kicker">
                    Kitchen and bar
                </span>

                <h2 class="panel-title">
                    Menu Mutations
                </h2>

                <p class="panel-copy">
                    Burgers, wings, beer, shots and everything in between.
                </p>

                <div class="panel-action">
                    Edit the menu →
                </div>
            </div>

        </a>

        <a asp-controller="Category"
           asp-action="Index"
           class="control-panel panel-categories">

            <div class="panel-small-number">
                @Model.CategoriesCount
            </div>

            <div>
                <span class="panel-kicker">
                    Structure
                </span>

                <h2 class="panel-title">
                    Categories
                </h2>

                <p class="panel-copy">
                    Keep the menu organised.
                </p>

                <div class="panel-action">
                    Open →
                </div>
            </div>

        </a>

        <a asp-controller="Home"
           asp-action="Index"
           target="_blank"
           class="control-panel panel-website">

            <div class="panel-small-number">
                ↗
            </div>

            <div>
                <span class="panel-kicker">
                    Public side
                </span>

                <h2 class="panel-title">
                    View Website
                </h2>

                <p class="panel-copy">
                    See what the guests see.
                </p>

                <div class="panel-action">
                    Open site ↗
                </div>
            </div>

        </a>

    </div>

    <section class="upcoming-section">

        <div class="upcoming-header">

            <div>
                <div class="upcoming-kicker">
                    Next in line
                </div>

                <h2 class="upcoming-title">
                    Upcoming Noise
                </h2>
            </div>

            <a asp-controller="AdminEvents"
               asp-action="Index"
               class="upcoming-view-all">

                View all events →
            </a>

        </div>

        @if (Model.UpcomingEvents.Any())
        {
            <div class="upcoming-grid">

                @foreach (var eventItem in Model.UpcomingEvents)
                {
                    var eventDateText =
                    eventItem.Date.ToString("dd MMM");

                    var descriptionText =
                    string.IsNullOrWhiteSpace(eventItem.Description)
                    ? "No description added."
                    : eventItem.Description.Length > 100
                    ? eventItem.Description[..100] + "..."
                    : eventItem.Description;

                    <a asp-controller="AdminEvents"
                       asp-action="Edit"
                       asp-route-id="@eventItem.Id"
                       class="upcoming-card">

                        <div class="upcoming-image">

                            @if (!string.IsNullOrWhiteSpace(eventItem.ImageUrl))
                            {
                                <img src="@eventItem.ImageUrl"
                                     alt="@eventItem.Title" />
                            }
                            else
                            {
                                <div class="upcoming-placeholder">
                                    NO IMAGE
                                </div>
                            }

                            <div class="upcoming-date">
                                @eventDateText
                            </div>

                        </div>

                        <div class="upcoming-body">

                            <h3 class="upcoming-event-title">
                                @eventItem.Title
                            </h3>

                            <p class="upcoming-description">
                                @descriptionText
                            </p>

                            <span class="upcoming-open">
                                Open event →
                            </span>

                        </div>

                    </a>
                }

            </div>
        }
        else
        {
            <div class="upcoming-empty">

                <h3>
                    No upcoming noise.
                </h3>

                <p>
                    The calendar is suspiciously quiet.
                </p>

                <a asp-controller="AdminEvents"
                   asp-action="Create">

                    Create an event
                </a>

            </div>
        }

    </section>

</section>
