@model Rebel.Web.Models.DashboardViewModel

@{
    ViewData["Title"] = "Start Here";
}

<div class="admin-workspace">

    <header class="admin-workspace-header">
        <div class="admin-workspace-heading">
            <span class="admin-workspace-eyebrow">
                Control room
            </span>

            <h1 class="admin-workspace-title">
                Start here
            </h1>

            <p class="admin-workspace-copy">
                The few things that need attention now. Everything else
                remains available from the left navigation.
            </p>
        </div>

        <div class="admin-workspace-actions">
            <a asp-controller="AdminReservations"
               asp-action="Tonight"
               class="admin-primary-button">
                Open tonight
            </a>
        </div>
    </header>

    <section class="admin-metric-bar"
             aria-label="Today summary">
        <a asp-controller="AdminReservations"
           asp-action="Index"
           asp-route-status="Pending"
           class="admin-metric is-attention">
            <span>New requests</span>
            <strong>@Model.TonightPendingReservationsCount</strong>
        </a>

        <a asp-controller="AdminReservations"
           asp-action="Tonight"
           class="admin-metric">
            <span>Tonight's guests</span>
            <strong>@Model.TonightGuestsCount</strong>
        </a>

        <a asp-controller="AdminReservations"
           asp-action="Index"
           asp-route-needsTable="true"
           class="admin-metric @(Model.TonightUnassignedTablesCount > 0 ? "is-attention" : "")">
            <span>Need table</span>
            <strong>@Model.TonightUnassignedTablesCount</strong>
        </a>
    </section>

    <details class="admin-filter-disclosure"
             open="@(!string.IsNullOrWhiteSpace(Model.SearchQuery) ? "open" : null)">
        <summary>
            <span>Find a guest, booking, event, or menu item</span>
            <span>Search</span>
        </summary>

        <form asp-controller="Admin"
              asp-action="Index"
              method="get"
              class="admin-filter-panel admin-dashboard-search">
            <label>
                Search
                <input type="search"
                       name="q"
                       value="@Model.SearchQuery"
                       placeholder="Reservation code, guest, event, item"
                       autocomplete="off" />
            </label>

            <button type="submit"
                    class="admin-primary-button">
                Search
            </button>

            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <a asp-controller="Admin"
                   asp-action="Index"
                   class="admin-secondary-button">
                    Clear
                </a>
            }
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            @if (Model.SearchResults.Count == 0)
            {
                <div class="admin-empty-state">
                    <strong>No results found.</strong>
                    <span>Try a guest surname, code, event, or menu item.</span>
                </div>
            }
            else
            {
                <div class="admin-list">
                    @foreach (var result in Model.SearchResults)
                    {
                        <a asp-controller="@result.Controller"
                           asp-action="@result.Action"
                           asp-route-id="@result.Id"
                           class="admin-list-row admin-search-result-row">
                            <div class="admin-row-copy">
                                <strong>@result.Title</strong>
                                <span>@result.Meta</span>
                            </div>

                            <span class="admin-state">@result.Type</span>
                        </a>
                    }
                </div>
            }
        }
    </details>

    <section class="admin-section">
        <header class="admin-section-heading">
            <div>
                <span class="admin-workspace-eyebrow">Work queue</span>
                <h2>Needs attention</h2>
            </div>
        </header>

        <div class="admin-list">
            <article class="admin-list-row @(Model.TonightPendingReservationsCount > 0 ? "is-attention" : "")">
                <div class="admin-row-copy">
                    <strong>New reservation requests</strong>
                    <span>Approve, reject, and assign a table.</span>
                </div>

                <div class="admin-row-data">
                    <strong>@Model.TonightPendingReservationsCount</strong>
                    <span>Waiting</span>
                </div>

                <span class="admin-state @(Model.TonightPendingReservationsCount > 0 ? "is-attention" : "")">
                    @(Model.TonightPendingReservationsCount > 0 ? "Action needed" : "Clear")
                </span>

                <div class="admin-row-actions">
                    <a asp-controller="AdminReservations"
                       asp-action="Index"
                       asp-route-status="Pending"
                       class="admin-primary-button">
                        Review
                    </a>
                </div>
            </article>

            <article class="admin-list-row @(Model.TonightUnassignedTablesCount > 0 ? "is-attention" : "")">
                <div class="admin-row-copy">
                    <strong>Bookings without a table</strong>
                    <span>Check the floor before service begins.</span>
                </div>

                <div class="admin-row-data">
                    <strong>@Model.TonightUnassignedTablesCount</strong>
                    <span>Bookings</span>
                </div>

                <span class="admin-state @(Model.TonightUnassignedTablesCount > 0 ? "is-attention" : "")">
                    @(Model.TonightUnassignedTablesCount > 0 ? "Action needed" : "Clear")
                </span>

                <div class="admin-row-actions">
                    <a asp-controller="AdminReservations"
                       asp-action="Index"
                       asp-route-needsTable="true"
                       class="admin-secondary-button">
                        Assign
                    </a>
                </div>
            </article>

            <article class="admin-list-row @(Model.EmailFailuresCount > 0 ? "is-danger" : "")">
                <div class="admin-row-copy">
                    <strong>Guest email delivery</strong>
                    <span>Failed messages can be resent from booking details.</span>
                </div>

                <div class="admin-row-data">
                    <strong>@Model.EmailFailuresCount</strong>
                    <span>Failures</span>
                </div>

                <span class="admin-state @(Model.EmailFailuresCount > 0 ? "is-danger" : "is-success")">
                    @(Model.EmailFailuresCount > 0 ? "Check" : "Healthy")
                </span>

                <div class="admin-row-actions">
                    <a asp-controller="AdminReservations"
                       asp-action="Index"
                       class="admin-secondary-button">
                        Open desk
                    </a>
                </div>
            </article>

            <article class="admin-list-row @(Model.UnavailableProductsCount > 0 ? "is-attention" : "")">
                <div class="admin-row-copy">
                    <strong>Unavailable menu items</strong>
                    <span>Items remain visible to guests as sold out.</span>
                </div>

                <div class="admin-row-data">
                    <strong>@Model.UnavailableProductsCount</strong>
                    <span>Items</span>
                </div>

                <span class="admin-state">
                    Menu
                </span>

                <div class="admin-row-actions">
                    <a asp-controller="Product"
                       asp-action="Index"
                       asp-route-isAvailable="false"
                       class="admin-secondary-button">
                        Manage
                    </a>
                </div>
            </article>
        </div>
    </section>

    <section class="admin-section">
        <header class="admin-section-heading">
            <div>
                <span class="admin-workspace-eyebrow">Floor queue</span>
                <h2>Next arrivals</h2>
            </div>

            <a asp-controller="AdminReservations"
               asp-action="Tonight"
               class="admin-secondary-button">
                Full timeline
            </a>
        </header>

        @if (Model.NextArrivals.Count == 0)
        {
            <div class="admin-empty-state">
                <strong>No approved arrivals waiting.</strong>
            </div>
        }
        else
        {
            <div class="admin-list">
                @foreach (var reservation in Model.NextArrivals)
                {
                    <article class="admin-list-row">
                        <div class="admin-row-main">
                            <div class="admin-row-data">
                                <strong>@reservation.ReservationTime.ToString(@"hh\:mm")</strong>
                                <span>Arrival</span>
                            </div>

                            <div class="admin-row-copy">
                                <strong>@reservation.FullName</strong>
                                <span>
                                    @reservation.NumberOfGuests guests /
                                    @(string.IsNullOrWhiteSpace(reservation.TableLabel)
                                        ? "No table"
                                        : $"Table {reservation.TableLabel}")
                                </span>
                            </div>
                        </div>

                        <span class="admin-state">Expected</span>

                        <div class="admin-row-actions">
                            <a asp-controller="AdminReservations"
                               asp-action="Details"
                               asp-route-id="@reservation.Id"
                               class="admin-secondary-button">
                                Open
                            </a>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    @if (Model.UpcomingEvents.Count > 0)
    {
        <details class="admin-content-disclosure">
            <summary>
                <span>Upcoming events</span>
                <span>@Model.UpcomingEvents.Count</span>
            </summary>

            <div class="admin-list">
                @foreach (var eventItem in Model.UpcomingEvents)
                {
                    <article class="admin-list-row">
                        <div class="admin-row-main">
                            @if (!string.IsNullOrWhiteSpace(eventItem.ImageUrl))
                            {
                                <img src="@Url.Content(eventItem.ImageUrl)"
                                     alt=""
                                     loading="lazy"
                                     class="admin-row-thumbnail" />
                            }

                            <div class="admin-row-copy">
                                <strong>@eventItem.Title</strong>
                                <span>@eventItem.Date.ToString("dd MMM yyyy")</span>
                            </div>
                        </div>

                        <span class="admin-state">Upcoming</span>

                        <div class="admin-row-actions">
                            <a asp-controller="AdminEvents"
                               asp-action="Edit"
                               asp-route-id="@eventItem.Id"
                               class="admin-secondary-button">
                                Open
                            </a>
                        </div>
                    </article>
                }
            </div>
        </details>
    }

</div>
