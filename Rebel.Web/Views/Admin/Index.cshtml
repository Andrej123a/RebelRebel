@model Rebel.Web.Models.DashboardViewModel

@{
    ViewData["Title"] = "Control Room";
}

<section class="control-room">

    <header class="control-hero">

        <div>
            <div class="control-eyebrow">
                Rebel Rebel by Fat Kitchen backstage operations
            </div>

            <h1 class="control-title">
                Control the<br />
                beautiful chaos.
            </h1>

            <p class="control-copy">
                Events, reservations, food and drinks — everything that keeps
                Rebel Rebel by Fat Kitchen loud, alive and slightly out of control.
            </p>
        </div>

        <div class="control-stamp">
            PRIVATE<br />
            ACCESS
        </div>

    </header>

    <section class="admin-quick-search">
        <div>
            <span>Quick jump</span>
            <h2>Find anything fast</h2>
            <p>
                Search guest names, phone numbers, reservation codes, events or menu items.
            </p>
        </div>

        <form asp-controller="Admin"
              asp-action="Index"
              method="get"
              class="admin-quick-search-form">
            <input type="search"
                   name="q"
                   value="@Model.SearchQuery"
                   placeholder="Try RR-ABC123, Andrej, beer, burger..."
                   autocomplete="off" />

            <button type="submit">
                Search
            </button>

            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <a asp-controller="Admin"
                   asp-action="Index">
                    Clear
                </a>
            }
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            <div class="admin-search-results">
                <header>
                    <span>
                        Results for "@Model.SearchQuery"
                    </span>
                    <strong>@Model.SearchResults.Count</strong>
                </header>

                @if (Model.SearchResults.Any())
                {
                    <div class="admin-search-list">
                        @foreach (var result in Model.SearchResults)
                        {
                            <a asp-controller="@result.Controller"
                               asp-action="@result.Action"
                               asp-route-id="@result.Id">
                                <span>@result.Type</span>
                                <strong>@result.Title</strong>
                                <small>@result.Meta</small>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p>
                        No matching reservations, events or menu items found.
                    </p>
                }
            </div>
        }
    </section>

    <section class="service-glance">
        <div class="service-glance-header">
            <div>
                <span>Today at a glance</span>
                <h2>Service Priorities</h2>
            </div>

            <a asp-controller="AdminReservations"
               asp-action="Tonight">
                Open live floor
            </a>
        </div>

        <div class="service-priority-grid">
            <a asp-controller="AdminReservations"
               asp-action="Index"
               asp-route-status="Pending"
               class="service-priority-card is-hot">
                <span>New requests</span>
                <strong>@Model.TonightPendingReservationsCount</strong>
                <small>need approve / reject</small>
            </a>

            <a asp-controller="AdminReservations"
               asp-action="Tonight"
               class="service-priority-card">
                <span>Next arrivals</span>
                <strong>@Model.NextArrivals.Count</strong>
                <small>approved guests coming in</small>
            </a>

            <a asp-controller="AdminReservations"
               asp-action="Index"
               class="service-priority-card is-warning">
                <span>Large parties</span>
                <strong>@Model.TonightLargePartiesCount</strong>
                <small>9+ guests tonight</small>
            </a>

            <a asp-controller="AdminEvents"
               asp-action="Index"
               class="service-priority-card">
                <span>Event bookings</span>
                <strong>@Model.TodayEventBookingsCount</strong>
                <small>reservations tied to events</small>
            </a>

            <a asp-controller="AdminReservations"
               asp-action="Index"
               class="service-priority-card @(Model.EmailFailuresCount > 0 ? "is-danger" : "")">
                <span>Email failures</span>
                <strong>@Model.EmailFailuresCount</strong>
                <small>guest messages to retry</small>
            </a>
        </div>

        <div class="service-work-grid">
            <div class="service-work-panel">
                <header>
                    <span>Arrival watch</span>
                    <a asp-controller="AdminReservations"
                       asp-action="Tonight">
                        Timeline
                    </a>
                </header>

                @if (Model.NextArrivals.Any())
                {
                    <div class="service-work-list">
                        @foreach (var reservation in Model.NextArrivals)
                        {
                            <a asp-controller="AdminReservations"
                               asp-action="Details"
                               asp-route-id="@reservation.Id">
                                <strong>@reservation.ReservationTime.ToString(@"hh\:mm")</strong>
                                <span>@reservation.FullName</span>
                                <small>
                                    @reservation.NumberOfGuests guests
                                    @(string.IsNullOrWhiteSpace(reservation.TableLabel)
                                        ? "/ no table"
                                        : $"/ table {reservation.TableLabel}")
                                </small>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p>No approved arrivals waiting for today.</p>
                }
            </div>

            <div class="service-work-panel">
                <header>
                    <span>Large groups</span>
                    <a asp-controller="AdminReservations"
                       asp-action="Index">
                        Review
                    </a>
                </header>

                @if (Model.LargePartyReservations.Any())
                {
                    <div class="service-work-list">
                        @foreach (var reservation in Model.LargePartyReservations)
                        {
                            <a asp-controller="AdminReservations"
                               asp-action="Details"
                               asp-route-id="@reservation.Id">
                                <strong>@reservation.NumberOfGuests</strong>
                                <span>@reservation.FullName</span>
                                <small>@reservation.ReservationTime.ToString(@"hh\:mm") / seating check</small>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p>No large parties on tonight's active floor.</p>
                }
            </div>

            <div class="service-work-panel">
                <header>
                    <span>Email failures</span>
                    <a asp-controller="AdminReservations"
                       asp-action="Index">
                        Open desk
                    </a>
                </header>

                @if (Model.EmailFailureReservations.Any())
                {
                    <div class="service-work-list">
                        @foreach (var reservation in Model.EmailFailureReservations)
                        {
                            <a asp-controller="AdminReservations"
                               asp-action="Details"
                               asp-route-id="@reservation.Id">
                                <strong>@reservation.ReservationTime.ToString(@"hh\:mm")</strong>
                                <span>@reservation.FullName</span>
                                <small>@reservation.EmailStatus / resend from details</small>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p>Guest email delivery looks clean.</p>
                }
            </div>

            <div class="service-work-panel">
                <header>
                    <span>Event covers</span>
                    <a asp-controller="AdminEvents"
                       asp-action="Index">
                        Event board
                    </a>
                </header>

                @if (Model.TodayEventBookings.Any())
                {
                    <div class="service-work-list">
                        @foreach (var eventSummary in Model.TodayEventBookings)
                        {
                            <a asp-controller="AdminEvents"
                               asp-action="Bookings"
                               asp-route-id="@eventSummary.EventId">
                                <strong>
                                    @(eventSummary.StartTime.HasValue
                                        ? eventSummary.StartTime.Value.ToString(@"hh\:mm")
                                        : "--")
                                </strong>
                                <span>@eventSummary.Title</span>
                                <small>
                                    @eventSummary.ReservationsCount bookings / @eventSummary.GuestsCount guests
                                </small>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p>No event-linked reservations for today.</p>
                }
            </div>
        </div>
    </section>

    <section class="attention-board">

        <div class="attention-panel">
            <div class="attention-panel-header">
                <div>
                    <span class="attention-kicker">
                        Front door
                    </span>

                    <h2>
                        Pending Requests
                    </h2>
                </div>

                <a asp-controller="AdminReservations"
                   asp-action="Index"
                   asp-route-status="Pending">
                    View all
                </a>
            </div>

            @if (Model.LatestPendingReservations.Any())
            {
                <div class="attention-list">
                    @foreach (var reservation in Model.LatestPendingReservations)
                    {
                        <a asp-controller="AdminReservations"
                           asp-action="Details"
                           asp-route-id="@reservation.Id"
                           class="attention-row">

                            <span class="attention-time">
                                @reservation.ReservationDate.ToString("dd MMM")
                                @reservation.ReservationTime.ToString(@"hh\:mm")
                            </span>

                            <strong>
                                @reservation.FullName
                            </strong>

                            <small>
                                @reservation.NumberOfGuests
                                @(reservation.NumberOfGuests == 1 ? "guest" : "guests")
                            </small>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="attention-empty">
                    No pending reservation requests right now.
                </p>
            }
        </div>

        <div class="attention-panel">
            <div class="attention-panel-header">
                <div>
                    <span class="attention-kicker">
                        Menu board
                    </span>

                    <h2>
                        Unavailable Items
                    </h2>
                </div>

                <a asp-controller="Product"
                   asp-action="Index"
                   asp-route-isAvailable="false">
                    Manage
                </a>
            </div>

            @if (Model.UnavailableProducts.Any())
            {
                <div class="attention-list">
                    @foreach (var product in Model.UnavailableProducts)
                    {
                        <a asp-controller="Product"
                           asp-action="Edit"
                           asp-route-id="@product.Id"
                           class="attention-row">

                            <span class="attention-time">
                                @(product.Category?.Name ?? "Uncategorized")
                            </span>

                            <strong>
                                @product.Name
                            </strong>

                            <small>
                                @product.Price.ToString("0.##") MKD
                            </small>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="attention-empty">
                    Everything on the menu is currently available.
                </p>
            }
        </div>

    </section>

    <section class="upcoming-section">

        <div class="upcoming-header">

            <div>
                <div class="upcoming-kicker">
                    Next in line
                </div>

                <h2 class="upcoming-title">
                    Upcoming Noise
                </h2>
            </div>

            <a asp-controller="AdminEvents"
               asp-action="Index"
               class="upcoming-view-all">

                View all events ->
            </a>

        </div>

        @if (Model.UpcomingEvents.Any())
        {
            <div class="upcoming-grid">

                @foreach (var eventItem in Model.UpcomingEvents)
                {
                    var eventDateText =
                    eventItem.Date.ToString("dd MMM");

                    var descriptionText =
                    string.IsNullOrWhiteSpace(eventItem.Description)
                    ? "No description added."
                    : eventItem.Description.Length > 100
                    ? eventItem.Description[..100] + "..."
                    : eventItem.Description;

                    <a asp-controller="AdminEvents"
                       asp-action="Edit"
                       asp-route-id="@eventItem.Id"
                       class="upcoming-card">

                        <div class="upcoming-image">

                            @if (!string.IsNullOrWhiteSpace(eventItem.ImageUrl))
                            {
                                <img src="@eventItem.ImageUrl"
                                     alt="@eventItem.Title" />
                            }
                            else
                            {
                                <div class="upcoming-placeholder">
                                    NO IMAGE
                                </div>
                            }

                            <div class="upcoming-date">
                                @eventDateText
                            </div>

                        </div>

                        <div class="upcoming-body">

                            <h3 class="upcoming-event-title">
                                @eventItem.Title
                            </h3>

                            <p class="upcoming-description">
                                @descriptionText
                            </p>

                            <span class="upcoming-open">
                                Open event ->
                            </span>

                        </div>

                    </a>
                }

            </div>
        }
        else
        {
            <div class="upcoming-empty">

                <h3>
                    No upcoming noise.
                </h3>

                <p>
                    The calendar is suspiciously quiet.
                </p>

                <a asp-controller="AdminEvents"
                   asp-action="Create">

                    Create an event
                </a>

            </div>
        }

    </section>

</section>
