@model Rebel.Domain.Entities.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="container py-5">
    <div class="card bg-dark text-light border-secondary shadow-sm">
        <div class="card-body">
            <h2 class="fw-bold mb-4">Edit Category</h2>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Type" class="form-label"></label>
                    <select asp-for="Type"
                            class="form-select"
                            asp-items="Html.GetEnumSelectList<Rebel.Domain.Enums.CategoryType>()">
                    </select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}