@model Rebel.Domain.Entities.Category

@{
    ViewData["Title"] = "Create Category";
    var isTypeLocked = Context.Request.Query["type"].Count > 0;
}

<section class="admin-editor-page">
    <header class="admin-editor-hero">
        <div>
            <small>Menu sections</small>
            <h1>Create Category</h1>
            <p>
                Add a clear menu section so staff can keep products grouped
                exactly how guests expect to browse them.
            </p>
        </div>

        <a asp-action="Index"
           class="admin-tool-button">
            Back to Categories
        </a>
    </header>

    <form asp-action="Create"
          method="post"
          class="admin-editor-form"
          autocomplete="off">
        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger">
        </div>

        <div class="admin-editor-grid is-simple">
            <section class="admin-editor-panel">
                <h2>Category Details</h2>
                <p class="admin-editor-help">
                    Keep names short and familiar. The category name appears
                    in the public menu and admin menu board.
                </p>

                <div class="admin-editor-field">
                    <label asp-for="Name"
                           class="form-label">
                    </label>

                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Beer, Burgers, Cocktails..." />

                    <span asp-validation-for="Name"
                          class="text-danger small">
                    </span>
                </div>

                <div class="admin-editor-field">
                    <label asp-for="Description"
                           class="form-label">
                    </label>

                    <textarea asp-for="Description"
                              class="form-control"
                              rows="4"
                              placeholder="Short internal/public description for this section"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger small">
                    </span>
                </div>

                <div class="admin-editor-field">
                    <label asp-for="Type"
                           class="form-label">
                    </label>

                    @if (isTypeLocked)
                    {
                        <select asp-for="Type"
                                class="form-select"
                                asp-items="Html.GetEnumSelectList<Rebel.Domain.Enums.CategoryType>()"
                                disabled>
                        </select>

                        <input type="hidden" asp-for="Type" />
                    }
                    else
                    {
                        <select asp-for="Type"
                                class="form-select"
                                asp-items="Html.GetEnumSelectList<Rebel.Domain.Enums.CategoryType>()">
                        </select>
                    }

                    <span asp-validation-for="Type"
                          class="text-danger small">
                    </span>
                </div>
            </section>

            <aside class="admin-editor-panel">
                <h2>Staff Check</h2>
                <ul class="admin-editor-note-list">
                    <li>Use one category for one real menu section.</li>
                    <li>Choose Food, Drink or Beer so filtering stays clean.</li>
                    <li>Products can be added immediately after saving.</li>
                </ul>
            </aside>
        </div>

        <div class="admin-editor-actions">
            <button type="submit"
                    class="btn btn-warning">
                Save Category
            </button>

            <a asp-action="Index"
               class="btn btn-outline-light">
                Cancel
            </a>
        </div>
    </form>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
