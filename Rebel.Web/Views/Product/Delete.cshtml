@model Rebel.Domain.Entities.Product

<h1 style="color:white;">Delete Product</h1>

<h3 style="color:white;">Are you sure you want to delete this product?</h3>

<div>
    <p style="color:white;"><strong>Name:</strong> @Model.Name</p>
    <p style="color:white;"><strong>Description:</strong> @Model.Description</p>
    <p style="color:white;"><strong>Price:</strong> @Model.Price</p>
    <p style="color:white;"><strong>Category:</strong> @Model.Category?.Name</p>
    <p style="color:white;"><strong>Available:</strong> @Model.IsAvailable</p>

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Name" width="120" />
    }
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Delete</button>
</form>

<div>
    <a asp-action="Index">Back to List</a>
</div>