@model Rebel.Domain.Entities.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-9">

            <div class="mb-4">
                <p class="text-danger text-uppercase fw-bold small mb-1">
                    Rebel Rebel Admin
                </p>

                <h1 class="fw-bold text-light mb-2">
                    Delete Product
                </h1>

                <p class="text-secondary mb-0">
                    Review the product before permanently deleting it.
                </p>
            </div>

            <div class="border border-danger rounded-4 overflow-hidden bg-dark">

                <div class="p-4 border-bottom border-danger">
                    <div class="d-flex align-items-start gap-3">
                        <div class="fs-2">⚠</div>

                        <div>
                            <h4 class="text-danger fw-bold mb-2">
                                Are you sure?
                            </h4>

                            <p class="text-light mb-0">
                                This action will permanently delete
                                <strong>@Model.Name</strong> and cannot be undone.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="row g-0">

                    <div class="col-lg-5">
                        <div class="h-100"
                             style="min-height: 330px; background: #161616;">

                            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                            {
                                <img src="@Url.Content(Model.ImageUrl)"
                                     alt="@Model.Name"
                                     class="w-100 h-100"
                                     style="object-fit: cover;
                                                min-height: 330px;
                                                max-height: 430px;" />
                            }
                            else
                            {
                                <div class="h-100 d-flex flex-column align-items-center justify-content-center text-center p-4"
                                     style="min-height: 330px;">

                                    <span class="display-4 mb-3">✦</span>

                                    <p class="text-light fw-semibold mb-1">
                                        No product image
                                    </p>

                                    <p class="text-secondary small mb-0">
                                        This product does not have an image.
                                    </p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="p-4 p-lg-5">

                            <h2 class="text-light fw-bold mb-4">
                                @Model.Name
                            </h2>

                            <dl class="row mb-0">

                                <dt class="col-sm-4 text-secondary mb-3">
                                    Description
                                </dt>

                                <dd class="col-sm-8 text-light mb-3">
                                    @(string.IsNullOrWhiteSpace(Model.Description)
                                                                        ? "No description available."
                                                                        : Model.Description)
                                </dd>

                                <dt class="col-sm-4 text-secondary mb-3">
                                    Category
                                </dt>

                                <dd class="col-sm-8 mb-3">
                                    @if (Model.Category != null)
                                    {
                                        <span class="badge bg-secondary">
                                            @Model.Category.Name
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary">
                                            No category
                                        </span>
                                    }
                                </dd>

                                <dt class="col-sm-4 text-secondary mb-3">
                                    Price
                                </dt>

                                <dd class="col-sm-8 text-warning fw-bold mb-3">
                                    @Model.Price.ToString("0.##") MKD
                                </dd>

                                <dt class="col-sm-4 text-secondary mb-3">
                                    Status
                                </dt>

                                <dd class="col-sm-8 mb-3">
                                    @if (Model.IsAvailable)
                                    {
                                        <span class="badge bg-success">
                                            Available
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Unavailable
                                        </span>
                                    }
                                </dd>

                            </dl>
                        </div>
                    </div>

                </div>
            </div>

            <form asp-action="Delete"
                  asp-route-id="@Model.Id"
                  method="post"
                  class="d-flex flex-wrap gap-3 mt-4">

                <input type="hidden" asp-for="Id" />

                <button type="submit"
                        class="btn btn-danger px-4 fw-semibold">
                    Delete Permanently
                </button>

                <a asp-action="Index"
                   class="btn btn-outline-light px-4">
                    Cancel
                </a>
            </form>

        </div>
    </div>
</div>