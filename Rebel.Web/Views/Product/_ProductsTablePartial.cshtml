@model IEnumerable<Rebel.Domain.Entities.Product>

@if (Model?.Any() == true)
{
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col">Image</th>
                    <th scope="col">Name</th>
                    <th scope="col">Category</th>
                    <th scope="col">Price</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="width: 85px;">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@Url.Content(item.ImageUrl)"
                                     alt="@item.Name"
                                     loading="lazy"
                                     class="rounded"
                                     style="width: 60px;
                                                        height: 60px;
                                                        object-fit: cover;
                                                        border: 1px solid rgba(255,255,255,0.15);" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center rounded text-secondary"
                                     style="width: 60px;
                                                        height: 60px;
                                                        background: #202020;
                                                        border: 1px solid rgba(255,255,255,0.15);
                                                        font-size: 11px;">
                                    No image
                                </div>
                            }
                        </td>

                        <td>
                            <span class="fw-semibold text-light">
                                @item.Name
                            </span>
                        </td>

                        <td>
                            @if (item.Category != null)
                            {
                                <span class="badge bg-secondary">
                                    @item.Category.Name
                                </span>
                            }
                            else
                            {
                                <span class="text-secondary">No category</span>
                            }
                        </td>

                        <td class="fw-semibold text-warning">
                            @item.Price.ToString("0.##") MKD
                        </td>

                        <td>
                            @if (item.IsAvailable)
                            {
                                <span class="badge bg-success">
                                    Available
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Unavailable
                                </span>
                            }
                        </td>

                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                <a asp-controller="Product"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-info">
                                    Edit
                                </a>

                                <a asp-controller="Product"
                                   asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5 border border-secondary rounded">
        <h5 class="text-light mb-2">No products found</h5>
        <p class="text-secondary mb-0">
            Try changing or resetting the selected filters.
        </p>
    </div>
}