                    <div class="rr-menu-food-rotator" aria-hidden="true">
                        <img src="https://imageproxy.wolt.com/assets/6a02e61c938b4b58b5c33754?w=960"
                             alt=""
                             class="rr-menu-food-image" />

                        <img src="https://imageproxy.wolt.com/assets/6a03117d3f815eb3031bd7ba?w=960"
                             alt=""
                             class="rr-menu-food-image" />

                        <img src="https://imageproxy.wolt.com/assets/6a02e63b938b4b58b5c33760?w=960"
                             alt=""
                             class="rr-menu-food-image" />

                        <img src="https://imageproxy.wolt.com/assets/6a02e5bc95fd7fae364fccb1?w=960"
                             alt=""
                             class="rr-menu-food-image" />
                    </div>

                    <span class="rr-menu-code">
                        01
                    </span>

                    <div class="rr-menu-content">

                        <span class="rr-menu-kicker">
                            Wings · Burgers · Pizza · Finger food
                        </span>

                        <h3>
                            Food with<br />
