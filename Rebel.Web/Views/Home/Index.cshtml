@{
    ViewData["Title"] = "Home";
    var featuredEvent = ViewBag.FeaturedEvent as Rebel.Domain.Entities.Event;
    var upcomingEvents = ViewBag.Events as List<Rebel.Domain.Entities.Event> ?? new List<Rebel.Domain.Entities.Event>();
}

@functions {
    public string FormatEventDate(DateTime date)
    {
        var today = DateTime.UtcNow.Date;
        var eventDate = date.Date;

        if (eventDate == today)
            return "Tonight";

        if (eventDate == today.AddDays(1))
            return "Tomorrow";

        if (eventDate <= today.AddDays(7))
            return $"This {eventDate:dddd}";

        return eventDate.ToString("dd MMM yyyy");
    }
}

<section class="hero-section d-flex align-items-center text-white">
    <div class="container hero-container">
        <div class="row align-items-center g-5 hero-row">
            <div class="col-lg-6">
                <div class="hero-content">
                    <span class="badge rounded-pill hero-badge mb-3 px-3 py-2">
                        Skopje • Alternative Pub Experience
                    </span>

                    <h1 class="display-2 fw-bold mb-3 hero-title">
                        Rebel Rebel
                    </h1>

                    <p class="hero-subtitle mb-3">
                        Cold beer. Loud music. No rules.
                    </p>

                    <p class="hero-text mb-4">
                        Not your average pub.
                        No filters, no pretenses — just good beer, real food and nights that go longer than planned.
                    </p>

                    <div class="d-flex gap-3 flex-wrap hero-actions">
                        <a asp-controller="Home" asp-action="Menu" asp-route-section="beer"
                           class="btn btn-warning btn-lg px-4">
                            🍺 Explore Beers
                        </a>

                        <a asp-controller="Home" asp-action="Menu" asp-route-section="food"
                           class="btn btn-outline-light btn-lg px-4">
                            🍔 View Menu
                        </a>

                        <a asp-controller="Home" asp-action="Contact"
                           class="btn btn-outline-warning btn-lg px-4">
                            📍 Contact Us
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="hero-visual">
                    <div class="hero-image-wrap">
                        <img src="~/images/hero.jpg" alt="Rebel Rebel hero" class="hero-image" />

                        <div class="hero-quote-card p-4 rounded-4 shadow-lg">
                            <p class="fs-4 mb-3">
                                “Good music. Good beer. No compromises.”
                            </p>
                            <span class="hero-quote-author">Rebel Rebel vibe</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about" class="about-section py-5 text-white">
    <div class="container py-5">
        <div class="row align-items-center g-5">

            <div class="col-lg-6">
                <span class="about-badge">REBEL REBEL VIBE</span>

                <h2 class="about-heading mt-3 mb-3">
                    More than a pub.<br />
                    A whole mood.
                </h2>

                <div class="about-accent-line mb-4"></div>

                <p class="about-lead">
                    Rebel Rebel is more than a pub. It is a place for people who want something different:
                    rare imported beers, <strong>bold food</strong>, a strong visual identity, and nights shaped by carefully selected music.
                </p>

                <p class="about-body-text">
                    Inspired by a rebellious spirit and a love for atmosphere, our space blends character,
                    sound and taste into one experience. Whether you come for a new beer, a favorite record,
                    or the energy of the place itself, Rebel Rebel is built to feel unforgettable.
                </p>
            </div>

            <div class="col-lg-6">
                <div class="about-visual">
                    <div class="about-image-frame">
                        <img src="~/images/pub-about.jpg"
                             alt="Rebel Rebel interior"
                             class="about-main-image" />
                    </div>

                    <div class="about-floating-card">
                        <span class="about-floating-label">Imported beers</span>
                        <h5 class="mb-2">Bold atmosphere.</h5>
                        <p class="mb-0">Beer, food and music in one rebellious experience.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<section id="serve" class="py-5 section-black text-white">
    <div class="container py-4 text-center">
        <h2 class="fw-bold section-title mb-3">What We Serve</h2>

        <p class="serve-text mb-4">
            Cold beers, bold flavors and good times. <br />
            Whether you're here for a quick drink or a full table – we've got you covered.
        </p>

        <div class="d-flex justify-content-center gap-3 flex-wrap mt-4">
            <a asp-controller="Home" asp-action="Menu" asp-route-section="food"
               class="btn btn-outline-light btn-lg px-4">
                🍔 Food
            </a>

            <a asp-controller="Home" asp-action="Menu" asp-route-section="beer"
               class="btn btn-warning btn-lg px-4">
                🍺 Beer
            </a>

            <a asp-controller="Home" asp-action="Menu" asp-route-section="drink"
               class="btn btn-outline-warning btn-lg px-4">
                🍹 Drinks
            </a>
        </div>
    </div>
</section>

<section class="events-combined py-5">
    <div class="container">
        <div class="text-center mb-5">
            <p class="events-subtitle">WHAT'S ON</p>
            <h2 class="events-title">Upcoming Nights</h2>
            <p class="events-description">
                The next reasons to show up, stay late and come back again.
            </p>
        </div>

        @if (featuredEvent != null)
        {
            <div class="row g-4 align-items-stretch">
                <div class="col-lg-7">
                    <a asp-controller="Events" asp-action="Details" asp-route-id="@featuredEvent.Id"
                       class="text-decoration-none text-reset d-block h-100">
                        <div class="featured-event-card h-100">
                            @if (!string.IsNullOrEmpty(featuredEvent.ImageUrl))
                            {
                                <img src="@featuredEvent.ImageUrl" alt="@featuredEvent.Title" class="featured-event-image" />
                            }
                            else
                            {
                                <div class="featured-event-image-placeholder">No Image</div>
                            }

                            <div class="featured-event-body">
                                <p class="featured-event-label">NEXT UP</p>
                                <h3 class="featured-event-title">@featuredEvent.Title</h3>
                                <p class="featured-event-date">@FormatEventDate(featuredEvent.Date)</p>

                                @if (featuredEvent.StartTime.HasValue)
                                {
                                    <p class="featured-event-time text-warning fw-bold small">
                                        Starts at @featuredEvent.StartTime.Value.ToString(@"hh\:mm")
                                    </p>
                                }

                                <p class="featured-event-description">@featuredEvent.Description</p>
                            </div>
                        </div>
                    </a>

                    <a asp-controller="Events" asp-action="Index" class="btn btn-warning mt-3">
                        View All Events
                    </a>
                </div>

                <div class="col-lg-5">
                    @if (upcomingEvents.Skip(1).Any())
                    {
                        <div class="d-flex flex-column gap-4 h-100">
                            @foreach (var e in upcomingEvents.Skip(1))
                            {
                                <a asp-controller="Events" asp-action="Details" asp-route-id="@e.Id"
                                   class="text-decoration-none text-reset">
                                    <div class="event-side-card d-flex">
                                        @if (!string.IsNullOrEmpty(e.ImageUrl))
                                        {
                                            <img src="@e.ImageUrl" class="event-side-img" alt="@e.Title" />
                                        }
                                        else
                                        {
                                            <div class="event-side-img-placeholder">No Image</div>
                                        }

                                        <div class="p-3">
                                            <p class="event-date mb-2">@FormatEventDate(e.Date)</p>

                                            @if (e.StartTime.HasValue)
                                            {
                                                <p class="text-warning small mb-1">
                                                    Starts at @e.StartTime.Value.ToString(@"hh\:mm")
                                                </p>
                                            }

                                            <h6 class="mb-2">@e.Title</h6>
                                            <p class="mb-0 text-secondary small">@e.Description</p>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-events-box h-100 d-flex align-items-center justify-content-center text-center">
                            <div>
                                <h4 class="mb-3">Only one event scheduled</h4>
                                <p class="mb-0">More upcoming nights will appear here soon.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="text-center">
                <div class="empty-events-box">
                    <h4 class="mb-3">No upcoming events right now</h4>
                    <p class="mb-0">Check back soon for new nights, live sets and special events.</p>
                </div>
            </div>
        }
    </div>
</section>

<section class="py-5 section-dark text-white">
    <div class="container py-4">
        <div class="row mb-4">
            <div class="col text-center">
                <h2 class="fw-bold section-title">Inside Rebel Rebel</h2>
                <p class="text-secondary">
                    A glimpse of the atmosphere, energy and style that define our space.
                </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <img src="~/images/gallery-1.jpg" class="img-fluid rounded-4 gallery-img shadow" alt="Pub gallery 1">
            </div>
            <div class="col-md-4">
                <img src="~/images/gallery-2.jpg" class="img-fluid rounded-4 gallery-img shadow" alt="Pub gallery 2">
            </div>
            <div class="col-md-4">
                <img src="~/images/gallery-3.jpg" class="img-fluid rounded-4 gallery-img shadow" alt="Pub gallery 3">
            </div>
        </div>
    </div>
</section>

<section class="py-5 quote-section text-white text-center">
    <div class="container py-4">
        <p class="display-6 fw-semibold mb-3">
            “Not your average pub.”
        </p>
        <p class="lead mb-0">
            Rare beer. Alternative sound. Rebel atmosphere.
        </p>
    </div>
</section>