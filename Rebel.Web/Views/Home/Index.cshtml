                             alt=""
                             class="rr-menu-beer-image" />

                        <img src="https://imageproxy.wolt.com/assets/686e194a9aa298f40fedbf30?w=960;fit=crop&amp;w=1200&amp;q=85"
                             alt=""
                             class="rr-menu-beer-image" />

                        <img src="https://imageproxy.wolt.com/assets/686e194a9aa298f40fedbf40?w=960;fit=crop&amp;w=1200&amp;q=85"
                             alt=""
                             class="rr-menu-beer-image" />

                        <img src="https://imageproxy.wolt.com/assets/686e194a9aa298f40fedbf39?w=960;fit=crop&amp;w=1200&amp;q=85"
                             alt=""
                             class="rr-menu-beer-image" />
                    </div>

                    <span class="rr-menu-code">
                        02
                    </span>

                    <div class="rr-menu-content">

                        <span class="rr-menu-kicker">
                            Bottles · Draft · Rare finds
                        </span>

                        <h3>
                            Beer beyond<br />
                            the usual.
                        </h3>

                        <div class="rr-menu-action">
                            Open the beer list →
                        </div>

                    </div>

                </a>

                <a asp-controller="Home"
                   asp-action="Menu"
                   asp-route-section="drink"
                   class="rr-menu-panel rr-menu-drinks">

                    <span class="rr-menu-code">
                        03
                    </span>

                    <div class="rr-menu-content">

                        <span class="rr-menu-kicker">
                            Spirits · Cocktails · Shots
                        </span>

                        <h3>
                            Liquid<br />
                            courage.
                        </h3>

                        <div class="rr-menu-action">
                            View drinks →
                        </div>

                    </div>

                </a>

            </div>

        </div>

    </section>

    <section class="rr-noise-section">

        <div class="rr-noise-backword" aria-hidden="true">
            NOISE
        </div>

        <div class="rr-container rr-noise-shell">

            <header class="rr-noise-heading">

                <div class="rr-noise-heading-copy">
                    <div class="rr-section-number rr-section-number-red">
                        03 / WHAT'S ON
                    </div>

                    <h2>
                        Upcoming
                        <span>noise.</span>
                    </h2>

                    <p>
                        Pick a night. Bring the crew. Leave the sensible plans at home.
                    </p>
                </div>

                <a asp-controller="Events"
                   asp-action="Index"
                   class="rr-noise-board-link">
                    <span>FULL EVENTS BOARD</span>
                    <strong>↗</strong>
                </a>

            </header>

            @if (featuredEvent != null)
            {
                var featuredLocalDate =
                GetSkopjeDate(featuredEvent.Date);

                var featuredDay =
                featuredLocalDate.ToString("dd");

                var featuredMonth =
                featuredLocalDate.ToString("MMM").ToUpperInvariant();

                var featuredYear =
                featuredLocalDate.ToString("yyyy");

                var featuredTime =
                featuredEvent.StartTime.HasValue
                ? featuredEvent.StartTime.Value.ToString(@"hh\:mm")
                : "TBA";

                var featuredDescription =
                string.IsNullOrWhiteSpace(featuredEvent.Description)
                ? "Another Rebel night is waiting."
                : featuredEvent.Description.Length > 165
                ? featuredEvent.Description[..165] + "..."
                : featuredEvent.Description;

                var upcomingNoise =
                Model.UpcomingEvents?.Take(4).ToList()
                ?? new System.Collections.Generic.List<Rebel.Domain.Entities.Event>();

                <div class="rr-noise-layout">

                    <a asp-controller="Events"
                       asp-action="Details"
                       asp-route-id="@featuredEvent.Id"
                       class="rr-noise-feature">

                        <div class="rr-noise-feature-media">

                            @if (!string.IsNullOrWhiteSpace(featuredEvent.ImageUrl))
                            {
                                <img src="@featuredEvent.ImageUrl"
                                     alt="@featuredEvent.Title" />
                            }
                            else
                            {
                                <div class="rr-noise-feature-placeholder">
                                    <span>REBEL REBEL</span>
                                    <strong>POSTER<br />LOADING</strong>
                                </div>
                            }

                            <div class="rr-noise-feature-shade"></div>
                            <div class="rr-noise-feature-lines"></div>

                            <span class="rr-noise-type @GetEventTypeClass(featuredEvent.EventType)">
                                @FormatEventType(featuredEvent.EventType)
                            </span>

                            <div class="rr-noise-date">
                                <strong>@featuredDay</strong>
                                <span>
                                    @featuredMonth<br />
                                    @featuredYear
                                </span>
                            </div>

                            <div class="rr-noise-stamp">
                                NEXT<br />UP
                            </div>

                        </div>

                        <div class="rr-noise-feature-copy">

                            <div class="rr-noise-feature-meta">
                                @FormatEventDate(featuredEvent.Date) · @featuredTime
                            </div>

                            <h3>
                                @featuredEvent.Title
                            </h3>

                            <p>
                                @featuredDescription
                            </p>

                            <span class="rr-noise-enter">
                                ENTER THE EVENT
                                <strong>↗</strong>
                            </span>

                        </div>

                    </a>

                    <aside class="rr-noise-setlist">

                        <div class="rr-noise-setlist-head">
                            <span>NEXT IN LINE</span>
                            <strong>SETLIST / 2026</strong>
                        </div>

                        @if (upcomingNoise.Any())
                        {
                            @for (var i = 0; i < upcomingNoise.Count; i++)
                            {
                                var eventItem = upcomingNoise[i];

                                var eventDateText =
                                FormatEventDate(eventItem.Date);

                                var eventTimeText =
                                eventItem.StartTime.HasValue
                                ? eventItem.StartTime.Value.ToString(@"hh\:mm")
                                : "TBA";

                                <a asp-controller="Events"
                                   asp-action="Details"
                                   asp-route-id="@eventItem.Id"
                                   class="rr-noise-line @(i % 2 == 0 ? "rr-noise-line-left" : "rr-noise-line-right")">

                                    <span class="rr-noise-line-number">
                                        @((i + 1).ToString("00"))
                                    </span>

                                    <span class="rr-noise-line-main">
                                        <small>
                                            @eventDateText · @eventTimeText
                                        </small>

                                        <strong>
                                            @eventItem.Title
                                        </strong>
                                    </span>

                                    <span class="rr-noise-line-arrow">
                                        ↗
                                    </span>

                                </a>
                            }
                        }
                        else
                        {
                            <div class="rr-noise-setlist-empty">
                                <span>MORE CHAOS SOON</span>
                                <p>
                                    New nights will land here as soon as they are announced.
                                </p>
                            </div>
                        }

                        <div class="rr-noise-setlist-foot">
                            <span>LIVE</span>
                            <i></i>
                            <span>LOUD</span>
                            <i></i>
                            <span>LATE</span>
                        </div>

                    </aside>

                </div>

                <div class="rr-noise-strip" aria-hidden="true">
                    <span>BEER COLD</span>
                    <i>✦</i>
                    <span>AMPLIFIERS LOUD</span>
                    <i>✦</i>
                    <span>TABLES LIMITED</span>
                    <i>✦</i>
                    <span>EXCUSES REJECTED</span>
                </div>
            }
            else
            {
                <div class="rr-noise-empty">
                    <span class="rr-noise-empty-number">00</span>

                    <div>
                        <small>THE CALM BEFORE THE RIOT</small>
                        <h3>Suspiciously quiet.</h3>
                        <p>
                            No upcoming events are published right now.
                            Check again before making responsible plans.
                        </p>
                    </div>

                    <a asp-controller="Events"
                       asp-action="Index">
                        CHECK EVENTS ↗
                    </a>
                </div>
            }

        </div>

    </section>

    <section class="rr-gallery-section">

        <div class="rr-container">

            <header class="rr-gallery-heading">

                <div class="rr-section-number">
                    04 / SEEN INSIDE
                </div>

                <h2>
                    The evidence.
                </h2>

                <p>
                    Atmosphere cannot be explained properly.
                    Here is the closest thing.
                </p>

            </header>

            <div class="rr-gallery-grid">

                <figure class="rr-gallery-item rr-gallery-one">

                    <img src="~/images/gallery-1.jpg"
                         alt="Rebel Rebel atmosphere" />

                    <figcaption>
                        LATE / LOUD / LOCAL
                    </figcaption>

                </figure>

                <figure class="rr-gallery-item rr-gallery-two">

                    <img src="~/images/gallery-2.jpg"
                         alt="Drinks at Rebel Rebel" />

                </figure>

                <div class="rr-gallery-text-card">

                    <span>
                        WARNING
                    </span>

                    <strong>
                        One drink may become six.
                    </strong>

                </div>

                <figure class="rr-gallery-item rr-gallery-three">

                    <img src="~/images/gallery-3.jpg"
                         alt="Inside Rebel Rebel pub" />

                </figure>

            </div>

        </div>

    </section>

    <section class="rr-booking-section">

        <div class="rr-container">

            <div class="rr-booking-panel">

                <div class="rr-booking-number">
                    05
                </div>

                <div class="rr-booking-copy">

                    <span>
                        Your table is not going to book itself.
                    </span>

                    <h2>
                        Bring the crew.<br />
                        We’ll handle the rest.
                    </h2>

                    <p>
                        Send a reservation request and wait for confirmation
                        from the Rebel Rebel team.
                    </p>

                </div>

                <div class="rr-booking-actions">

                    <a asp-controller="Reservations"
                       asp-action="Create"
                       class="rr-booking-button">

                        Book a Table
                        <span>↗</span>
                    </a>

                    <a asp-controller="Home"
                       asp-action="Contact"
                       class="rr-contact-link">
                        Find us / Contact →
                    </a>

                </div>

            </div>

        </div>

    </section>

</div>
<style>
    .rr-noise-section {
        --rr-noise-yellow: #ffc400;
        --rr-noise-red: #e5232f;
        --rr-noise-ink: #070707;
        position: relative;
        padding: 112px 0 125px;
        overflow: hidden;
        color: #f4f1e9;
        background: radial-gradient(circle at 87% 35%, rgba(229, 35, 47, 0.16), transparent 27%), linear-gradient(180deg, #090909 0%, #050505 100%);
        isolation: isolate;
    }

        .rr-noise-section::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -2;
            opacity: 0.34;
            background: repeating-linear-gradient( 94deg, transparent 0, transparent 38px, rgba(255, 255, 255, 0.025) 39px, transparent 40px );
            pointer-events: none;
        }

        .rr-noise-section::after {
            content: "";
            position: absolute;
            right: -8%;
            bottom: 7%;
            z-index: -1;
            width: 42%;
            height: 42%;
            background: rgba(229, 35, 47, 0.08);
            filter: blur(95px);
            transform: rotate(-12deg);
            pointer-events: none;
        }

    .rr-noise-shell {
        position: relative;
        z-index: 2;
    }

    .rr-noise-backword {
        position: absolute;
        top: 40px;
        right: -45px;
        z-index: 0;
        color: transparent;
        font-family: Impact, "Arial Black", sans-serif;
        font-size: clamp(10rem, 23vw, 25rem);
        line-height: 0.8;
        letter-spacing: -0.045em;
        white-space: nowrap;
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.045);
        transform: rotate(5deg);
        pointer-events: none;
    }

    .rr-noise-heading {
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 45px;
        margin-bottom: 66px;
    }

    .rr-noise-heading-copy h2 {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.16em;
        margin: 8px 0 0;
        font-family: Impact, "Arial Black", sans-serif;
        font-size: clamp(4.8rem, 9vw, 8.8rem);
        line-height: 0.82;
        font-weight: 900;
        letter-spacing: -0.035em;
        text-transform: uppercase;
    }

        .rr-noise-heading-copy h2 span {
            position: relative;
            color: transparent;
            -webkit-text-stroke: 2px var(--rr-noise-yellow);
            transform: translateY(9px) rotate(-2deg);
        }

            .rr-noise-heading-copy h2 span::after {
                content: "";
                position: absolute;
                right: 0;
                bottom: -11px;
                left: 2%;
                height: 7px;
                background: var(--rr-noise-red);
                transform: rotate(-1.5deg);
            }

    .rr-noise-heading-copy p {
        max-width: 600px;
        margin: 31px 0 0 5px;
        color: #8e8e8e;
        font-size: 1rem;
        line-height: 1.75;
    }

    .rr-noise-board-link {
        display: inline-flex;
        align-items: center;
        gap: 21px;
        padding: 14px 0 12px;
        color: var(--rr-noise-yellow);
        border-bottom: 2px solid var(--rr-noise-yellow);
        font-size: 0.72rem;
        font-weight: 950;
        letter-spacing: 0.15em;
        text-decoration: none;
        transform: rotate(-1deg);
        transition: gap 0.25s ease, color 0.25s ease;
    }

        .rr-noise-board-link strong {
            color: #ffffff;
            font-size: 1.25rem;
        }

        .rr-noise-board-link:hover {
            gap: 30px;
            color: #ffffff;
        }

    .rr-noise-layout {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.58fr) minmax(320px, 0.82fr);
        gap: clamp(38px, 5vw, 82px);
        align-items: center;
    }

    .rr-noise-feature {
        position: relative;
        display: block;
        min-height: 675px;
        overflow: hidden;
        color: #ffffff;
        text-decoration: none;
        background: #111111;
        clip-path: polygon(0 2%, 96% 0, 100% 94%, 4% 100%);
        transform: rotate(-0.55deg);
        filter: drop-shadow(0 36px 55px rgba(0, 0, 0, 0.52));
        isolation: isolate;
    }

        .rr-noise-feature::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: 12;
            border: 1px solid rgba(255, 255, 255, 0.16);
            clip-path: inherit;
            pointer-events: none;
        }

        .rr-noise-feature::after {
            content: "";
            position: absolute;
            right: 9%;
            bottom: 7%;
            z-index: 9;
            width: 150px;
            height: 12px;
            background: var(--rr-noise-yellow);
            box-shadow: 42px -18px 0 -3px var(--rr-noise-red);
            transform: rotate(-3deg);
            pointer-events: none;
        }

    .rr-noise-feature-media {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }

        .rr-noise-feature-media > img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scale(1.035);
            filter: contrast(1.05) saturate(0.92);
            transition: transform 0.8s cubic-bezier(0.2, 0.75, 0.25, 1), filter 0.5s ease;
