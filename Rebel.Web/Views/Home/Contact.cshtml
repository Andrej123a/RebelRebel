@{
    ViewData["Title"] = "Contact";
}

<div class="contact-page py-5">
    <div class="container">
        <div class="text-center mb-5">
            <p class="contact-subtitle">GET IN TOUCH</p>
            <h1 class="contact-title">Contact Rebel Rebel Pub</h1>
            <p class="contact-description">
                Visit us for great beer, quality food and an unforgettable pub atmosphere.
            </p>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-lg-6">
                <div class="contact-card h-100">
                    <h3 class="contact-card-title mb-4">Visit Rebel Rebel</h3>

                    <div class="contact-item mb-3">
                        <strong>Address:</strong>
                        <p class="mb-0">Naum Naumovski Borce 62, Skopje 1000</p>
                    </div>

                    <div class="contact-item mb-3">
                        <strong>Working Hours:</strong>
                        <p class="mb-0">Mon - Sun: 12:00 - 01:00</p>
                    </div>

                    <div class="contact-item mb-3">
                        <strong>Phone:</strong>
                        <p class="mb-0">+389 70 123 456</p>
                    </div>

                    <div class="contact-item mb-3">
                        <strong>Email:</strong>
                        <p class="mb-0">info@rebelrebelpub.mk</p>
                    </div>

                    <div class="contact-item mb-0">
                        <strong>Instagram:</strong>
                        <p class="mb-0">@@rebelrebelpub</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="contact-card h-100">
                    <h3 class="contact-card-title mb-4">Why Visit Us?</h3>
                    <p>
                        Rebel Rebel Pub is the perfect place for beer lovers, food enthusiasts and everyone looking
                        for a relaxed but vibrant atmosphere in the heart of the city.
                    </p>
                    <p>
                        Enjoy a carefully selected range of beers, refreshing drinks, delicious burgers and pub food,
                        all served in a warm and energetic setting.
                    </p>
                    <p class="mb-0">
                        Whether you are meeting friends, planning a casual night out or just stopping by for a drink,
                        we would love to welcome you.
                    </p>
                </div>
            </div>
        </div>

        <div class="contact-card map-card p-0 overflow-hidden">
            <iframe src="https://www.google.com/maps?q=Naum%20Naumovski%20Borce%2062,%20Skopje&output=embed"
                    width="100%"
                    height="400"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>
    </div>
</div>