@model Rebel.Web.Models.AdminFloorPlanViewModel

@{
    ViewData["Title"] = "Tables";

    var activeTables = Model.Tables.Count(item => item.Table.IsActive);
    var inactiveTables = Model.Tables.Count(item => !item.Table.IsActive);

    var activeCapacity = Model.Tables
        .Where(item => item.Table.IsActive)
        .Sum(item => item.Table.Capacity);

    var tableGroups = Model.Tables
        .GroupBy(item =>
            string.IsNullOrWhiteSpace(item.Table.Area)
                ? "Main floor"
                : item.Table.Area)
        .OrderBy(group => group.Key)
        .ToList();
}

<div class="admin-workspace">

    <header class="admin-workspace-header">
        <div class="admin-workspace-heading">
            <span class="admin-workspace-eyebrow">
                Floor plan
            </span>

            <h1 class="admin-workspace-title">
                Tables
            </h1>

            <p class="admin-workspace-copy">
                These are the real tables staff can assign to approved
                reservations. Inactive tables disappear from assignment.
            </p>
        </div>

        <div class="admin-workspace-actions">
            <a asp-controller="AdminTables"
               asp-action="Create"
               class="admin-primary-button">
                Add table
            </a>

            <a asp-controller="AdminReservations"
               asp-action="Tonight"
               class="admin-secondary-button">
                Tonight
            </a>
        </div>
    </header>

    <section class="admin-metric-bar"
             aria-label="Floor summary">
        <div class="admin-metric">
            <span>Active tables</span>
            <strong>@activeTables</strong>
        </div>

        <div class="admin-metric">
            <span>Active capacity</span>
            <strong>@activeCapacity</strong>
        </div>

        <div class="admin-metric @(inactiveTables > 0 ? "is-attention" : "")">
            <span>Inactive</span>
            <strong>@inactiveTables</strong>
        </div>
    </section>

    @if (Model.Tables.Count == 0)
    {
        <div class="admin-empty-state">
            <strong>No tables configured.</strong>
            <span>Add the real floor before assigning reservation tables.</span>
        </div>
    }
    else
    {
        @for (var index = 0; index < tableGroups.Count; index++)
        {
            var group = tableGroups[index];
            var groupCapacity = group
                .Where(item => item.Table.IsActive)
                .Sum(item => item.Table.Capacity);

            <details class="admin-content-disclosure table-zone-disclosure"
                     open="@(index == 0 ? "open" : null)">
                <summary>
                    <span>@group.Key</span>
                    <span>
                        @group.Count(item => item.Table.IsActive) active /
                        @groupCapacity seats
                    </span>
                </summary>

                <div class="admin-list">
                    @foreach (var item in group.OrderBy(item => item.Table.Label))
                    {
                        var table = item.Table;
                        var reservation = item.OperationalReservation;
                        var isToday =
                            reservation?.ReservationDate ==
                                Model.CurrentLocalDate;

                        var isTomorrow =
                            reservation?.ReservationDate ==
                                Model.CurrentLocalDate.AddDays(1);

                        var reservationDateLabel =
                            isToday ? "Today" :
                            isTomorrow ? "Tomorrow" :
                            reservation?.ReservationDate.ToString("ddd, dd MMM");

                        <article class="admin-list-row table-floor-row @(!table.IsActive ? "is-danger" : item.IsOccupied ? "is-attention" : "")">
                            <div class="admin-row-main">
                                <div class="admin-row-copy">
                                    <strong>@table.Label</strong>
                                    <span>@group.Key</span>
                                </div>
                            </div>

                            <div class="admin-row-data">
                                <strong>@table.Capacity seats</strong>
                                <span>Maximum party size</span>
                            </div>

                            <div class="table-next-booking @(reservation == null ? "is-empty" : "")">
                                @if (reservation == null)
                                {
                                    <span>Next booking</span>
                                    <strong>Schedule clear</strong>
                                    <small>No upcoming reservation</small>
                                }
                                else
                                {
                                    <span>
                                        @(item.IsOccupied
                                            ? "Current booking"
                                            : "Next booking")
                                    </span>

                                    <a asp-controller="AdminReservations"
                                       asp-action="Details"
                                       asp-route-id="@reservation.Id">
                                        @(item.IsOccupied
                                            ? "Occupied now"
                                            : $"{reservationDateLabel} / {reservation.ReservationTime:hh\\:mm}")
                                    </a>

                                    <small>
                                        @reservation.FullName /
                                        @reservation.NumberOfGuests
                                        @(reservation.NumberOfGuests == 1
                                            ? "guest"
                                            : "guests")
                                    </small>
                                }
                            </div>

                            <span class="admin-state @(!table.IsActive ? "is-danger" : item.IsOccupied ? "is-attention" : "is-success")">
                                @(!table.IsActive
                                    ? "Inactive"
                                    : item.IsOccupied
                                        ? "Occupied"
                                        : "Assignable")
                            </span>

                            <div class="admin-row-actions">
                                <a asp-controller="AdminTables"
                                   asp-action="Edit"
                                   asp-route-id="@table.Id"
                                   class="admin-secondary-button">
                                    Edit
                                </a>

                                <details class="admin-more-menu">
                                    <summary>More</summary>

                                    <div class="admin-more-panel">
                                        <a asp-controller="AdminTables"
                                           asp-action="Edit"
                                           asp-route-id="@table.Id">
                                            Edit table
                                        </a>

                                        <form asp-controller="AdminTables"
                                              asp-action="ToggleActive"
                                              asp-route-id="@table.Id"
                                              method="post">
                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="@(!table.IsActive ? "" : "is-danger")">
                                                @(table.IsActive
                                                    ? "Make inactive"
                                                    : "Make assignable")
                                            </button>
                                        </form>
                                    </div>
                                </details>
                            </div>
                        </article>
                    }
                </div>
            </details>
        }
    }

</div>
