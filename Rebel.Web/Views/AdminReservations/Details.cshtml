@model Rebel.Domain.Entities.Reservation

@using Rebel.Domain.Enums

@{
    ViewData["Title"] = "Review Reservation";

    var skopjeTimeZone =
        TimeZoneInfo.FindSystemTimeZoneById("Europe/Skopje");

    var createdAtUtc = DateTime.SpecifyKind(
        Model.CreatedAtUtc,
        DateTimeKind.Utc);

    var createdInSkopje = TimeZoneInfo.ConvertTimeFromUtc(
        createdAtUtc,
        skopjeTimeZone);

    var reservationDateText =
        Model.ReservationDate.ToString("dd MMMM yyyy");

    var reservationTimeText =
        Model.ReservationTime.ToString(@"hh\:mm");

    var guestNote = string.IsNullOrWhiteSpace(Model.Note)
        ? "No guest note."
        : Model.Note;

    var adminResponse = string.IsNullOrWhiteSpace(Model.AdminNote)
        ? "No admin response yet."
        : Model.AdminNote;

    var internalNote = string.IsNullOrWhiteSpace(Model.InternalNote)
        ? "No staff note yet."
        : Model.InternalNote;

    var tableLabel = string.IsNullOrWhiteSpace(Model.TableLabel)
        ? "Not assigned"
        : Model.TableLabel;

    var activeTables =
        ViewBag.ActiveTables as List<Rebel.Domain.Entities.PubTable>
        ?? new List<Rebel.Domain.Entities.PubTable>();

    var busyTables =
        ViewBag.BusyTables as List<string>
        ?? new List<string>();

    var reservationActivities =
        ViewBag.ReservationActivities as List<Rebel.Domain.Entities.ReservationActivity>
        ?? new List<Rebel.Domain.Entities.ReservationActivity>();

    var recommendedTable = activeTables
        .Where(table =>
            !busyTables.Contains(table.Label) &&
            table.Capacity >= Model.NumberOfGuests)
        .OrderBy(table => table.Capacity)
        .ThenBy(table => table.Area)
        .ThenBy(table => table.Label)
        .FirstOrDefault();

    var assignableTablesCount = activeTables.Count(table =>
        !busyTables.Contains(table.Label) &&
        table.Capacity >= Model.NumberOfGuests);

    var busyTablesCount = activeTables.Count(table =>
        busyTables.Contains(table.Label));

    var tooSmallTablesCount = activeTables.Count(table =>
        !busyTables.Contains(table.Label) &&
        Model.NumberOfGuests > table.Capacity);

    var canEditFloor =
        Model.Status != ReservationStatus.Rejected &&
        Model.Status != ReservationStatus.NoShow &&
        Model.Status != ReservationStatus.Cancelled;

    var canCancel =
        Model.Status == ReservationStatus.Pending ||
        Model.Status == ReservationStatus.Approved;

    var isLargeParty =
        Model.NumberOfGuests >= 9;

    var requiresLargePartyNote =
        Model.NumberOfGuests >= 13;

    var serviceSummary =
        Model.Status == ReservationStatus.Pending
            ? "Awaiting manager decision"
            : Model.Status == ReservationStatus.Approved
                ? "Confirmed for service"
                : Model.Status == ReservationStatus.Arrived
                    ? "Guest checked in"
                    : Model.Status == ReservationStatus.NoShow
                        ? "Closed as no-show"
                        : Model.Status == ReservationStatus.Cancelled
                            ? "Cancelled"
                            : "Declined";

    string StatusClass(ReservationStatus status)
    {
        return status switch
        {
            ReservationStatus.Pending => "is-pending",
            ReservationStatus.Approved => "is-approved",
            ReservationStatus.Arrived => "is-arrived",
            ReservationStatus.NoShow => "is-no-show",
            ReservationStatus.Cancelled => "is-cancelled",
            ReservationStatus.Rejected => "is-rejected",
            _ => string.Empty
        };
    }

    string StatusLabel(ReservationStatus status)
    {
        return status == ReservationStatus.NoShow
            ? "No-show"
            : status.ToString();
    }

    string EmailStatusClass(string? status)
    {
        return status?.Contains("Failed", StringComparison.OrdinalIgnoreCase) == true
            ? "is-failed"
            : status?.Contains("Sent", StringComparison.OrdinalIgnoreCase) == true
                ? "is-sent"
                : "is-pending";
    }

    string EmailStatusLabel(string? status)
    {
        return status switch
        {
            "RequestSent" => "Request email sent",
            "ApprovedSent" => "Approval email sent",
            "RejectedSent" => "Rejection email sent",
            "CancelledSent" => "Cancel email sent",
            "RequestEmailFailed" => "Request email failed",
            "ApprovedEmailFailed" => "Approval email failed",
            "RejectedEmailFailed" => "Rejection email failed",
            "CancelledEmailFailed" => "Cancel email failed",
            _ => "Email pending"
        };
    }

    string EmailStatusDetail()
    {
        if (!string.IsNullOrWhiteSpace(Model.LastEmailError))
        {
            return Model.LastEmailError;
        }

        if (Model.LastEmailSentAtUtc.HasValue)
        {
            var sentAtUtc = DateTime.SpecifyKind(
                Model.LastEmailSentAtUtc.Value,
                DateTimeKind.Utc);

            var sentInSkopje = TimeZoneInfo
                .ConvertTimeFromUtc(sentAtUtc, skopjeTimeZone)
                .ToString("dd MMM yyyy, HH:mm");

            return $"Last sent {sentInSkopje}.";
        }

        return "No guest email has been recorded yet.";
    }
}

<section class="reservation-review-page">

    <a asp-controller="AdminReservations"
       asp-action="Index"
       class="reservation-review-back">
        Back to Reservation Desk
    </a>

    <header class="reservation-review-hero @StatusClass(Model.Status)">
        <div>
            <p>Reservation Review</p>
            <h1>@Model.FullName</h1>
            <span>@Model.ReservationCode / @serviceSummary</span>
        </div>

        <div class="reservation-review-status">
            <span>Status</span>
            <strong>@StatusLabel(Model.Status)</strong>
        </div>
    </header>

    <div class="reservation-service-strip">
        <div>
            <span>Party</span>
            <strong>@Model.NumberOfGuests</strong>
            <small>@(Model.NumberOfGuests == 1 ? "guest" : "guests")</small>
        </div>

        <div>
            <span>Arrival</span>
            <strong>@reservationTimeText</strong>
            <small>@reservationDateText</small>
        </div>

        <div>
            <span>Suggested table</span>
            <strong>@(recommendedTable?.Label ?? "None")</strong>
            <small>
                @(recommendedTable == null
                    ? "No available table fits"
                    : $"{recommendedTable.Capacity} seats")
            </small>
        </div>

        <div>
            <span>Contact</span>
            <strong>
                <a href="tel:@Model.PhoneNumber">@Model.PhoneNumber</a>
            </strong>
            <small>
                <a href="mailto:@Model.Email">@Model.Email</a>
            </small>
        </div>
    </div>

    @if (isLargeParty)
    {
        <div class="reservation-large-party-alert @(requiresLargePartyNote ? "strong" : "")">
            <span>
                @(requiresLargePartyNote ? "Large group review" : "Large party")
            </span>
            <strong>
                @Model.NumberOfGuests guests
            </strong>
            <p>
                @(requiresLargePartyNote
                    ? "Confirm seating plan before approval. Guest note is required for groups of 13 or more."
                    : "Check table layout before approval. This party may need joined tables or a specific area.")
            </p>
        </div>
    }

    @if (Model.Event != null)
    {
        <div class="reservation-event-alert">
            <span>Event booking</span>
            <strong>@Model.Event.Title</strong>
            <p>
                Confirm this reservation against the event guest list and capacity before approval.
            </p>
        </div>
    }

    @if (Model.EmailStatus?.Contains("Failed", StringComparison.OrdinalIgnoreCase) == true)
    {
        <div class="reservation-email-alert @EmailStatusClass(Model.EmailStatus)">
            <span>Email issue</span>
            <strong>@EmailStatusLabel(Model.EmailStatus)</strong>
            <div>
                <p>@EmailStatusDetail()</p>

                <form asp-controller="AdminReservations"
                      asp-action="ResendGuestEmail"
                      asp-route-id="@Model.Id"
                      method="post"
                      class="reservation-email-resend-form">
                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="reservation-email-resend-button">
                        Resend Guest Email
                    </button>
                </form>
            </div>
        </div>
    }

    <section class="reservation-review-panel reservation-floor-panel">
        <div class="reservation-review-section-title">
            <span>01</span>
            <h2>Table and Staff Note</h2>
        </div>

        <div class="reservation-floor-brief">
            <strong>
                @(recommendedTable == null
                    ? "No automatic table match"
                    : $"Recommended: {recommendedTable.Label}")
            </strong>
            <span>
                @assignableTablesCount assignable /
                @busyTablesCount busy /
                @tooSmallTablesCount too small
            </span>
        </div>

        @if (canEditFloor)
        {
            @if (assignableTablesCount == 0)
            {
                <div class="reservation-floor-warning">
                    <strong>No table can currently take this party.</strong>
                    <span>
                        Check capacity, move another booking, add a larger table,
                        or approve without a table and handle seating manually.
                    </span>
                </div>
            }

            <form asp-controller="AdminReservations"
                  asp-action="UpdateFloorDetails"
                  method="post"
                  class="reservation-floor-form">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="id"
                       value="@Model.Id" />

                <label>
                    Table assignment
                    <select name="tableLabel">
                        <option value="">Not assigned</option>

                        @foreach (var table in activeTables)
                        {
                            var isBusy = busyTables.Contains(table.Label);
                            var isTooSmall = Model.NumberOfGuests > table.Capacity;
                            var tableText = $"{table.Label} / {table.Capacity} seats";

                            if (!string.IsNullOrWhiteSpace(table.Area))
                            {
                                tableText = $"{table.Area} / {tableText}";
                            }

                            if (isBusy)
                            {
                                tableText = $"{tableText} / busy";
                            }
                            else if (isTooSmall)
                            {
                                tableText = $"{tableText} / too small";
                            }

                            if (Model.TableLabel == table.Label)
                            {
                                <option value="@table.Label" selected>
                                    @tableText
                                </option>
                            }
                            else if (recommendedTable?.Label == table.Label &&
                                     string.IsNullOrWhiteSpace(Model.TableLabel))
                            {
                                <option value="@table.Label" selected>
                                    @tableText / recommended
                                </option>
                            }
                            else
                            {
                                <option value="@table.Label"
                                        disabled="@(isBusy || isTooSmall)">
                                    @tableText
                                </option>
                            }
                        }
                    </select>
                </label>

                <label>
                    Internal staff note
                    <input name="internalNote"
                           value="@Model.InternalNote"
                           maxlength="500"
                           placeholder="Birthday, regular guest, avoid bar seats..." />
                </label>

                <button type="submit">
                    Save
                </button>
            </form>
        }
        else
        {
            <div class="reservation-review-note">
                <span>Staff note</span>
                <p>@internalNote</p>
            </div>
        }
    </section>

    @if (Model.Status == ReservationStatus.Pending)
    {
        <section class="reservation-decision-grid">
            <form asp-controller="AdminReservations"
                  asp-action="Approve"
                  method="post"
                  class="reservation-decision-card approve">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="id"
                       value="@Model.Id" />

                <span>Decision</span>
                <h2>Approve</h2>

                <select name="tableLabel">
                    <option value=""
                            selected="@(recommendedTable == null)">
                        Approve without table
                    </option>

                    @foreach (var table in activeTables)
                    {
                        var isBusy = busyTables.Contains(table.Label);
                        var isTooSmall = Model.NumberOfGuests > table.Capacity;
                        var tableText = $"{table.Label} / {table.Capacity} seats";

                        if (!string.IsNullOrWhiteSpace(table.Area))
                        {
                            tableText = $"{table.Area} / {tableText}";
                        }

                        if (isBusy)
                        {
                            tableText = $"{tableText} / busy";
                        }
                        else if (isTooSmall)
                        {
                            tableText = $"{tableText} / too small";
                        }

                        if (recommendedTable?.Label == table.Label)
                        {
                            <option value="@table.Label"
                                    selected
                                    disabled="@(isBusy || isTooSmall)">
                                @tableText / recommended
                            </option>
                        }
                        else
                        {
                            <option value="@table.Label"
                                    disabled="@(isBusy || isTooSmall)">
                                @tableText
                            </option>
                        }
                    }
                </select>

                <textarea name="adminNote"
                          rows="2"
                          maxlength="500"
                          placeholder="Optional guest-facing message..."></textarea>

                <textarea name="internalNote"
                          rows="2"
                          maxlength="500"
                          placeholder="Internal note, not sent to guest..."></textarea>

                <button type="submit">
                    Approve
                </button>
            </form>

            <form asp-controller="AdminReservations"
                  asp-action="Reject"
                  method="post"
                  class="reservation-decision-card reject">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="id"
                       value="@Model.Id" />

                <span>Decision</span>
                <h2>Reject</h2>

                <textarea name="adminNote"
                          rows="4"
                          maxlength="500"
                          placeholder="Optional reason or alternative time..."></textarea>

                <button type="submit">
                    Reject Reservation
                </button>
            </form>
        </section>
    }

    <div class="reservation-review-grid">
        <section class="reservation-review-panel">
            <div class="reservation-review-section-title">
                <span>02</span>
                <h2>Guest Details</h2>
            </div>

            <dl class="reservation-review-facts">
                <div>
                    <dt>Email</dt>
                    <dd>@Model.Email</dd>
                </div>

                <div>
                    <dt>Phone</dt>
                    <dd>@Model.PhoneNumber</dd>
                </div>

                <div>
                    <dt>Submitted</dt>
                    <dd>@createdInSkopje.ToString("dd MMM, HH:mm")</dd>
                </div>

                @if (Model.Event != null)
                {
                    <div class="wide">
                        <dt>Event</dt>
                        <dd>@Model.Event.Title</dd>
                    </div>
                }
            </dl>

            <div class="reservation-review-note">
                <span>Guest note</span>
                <p>@guestNote</p>
            </div>

            <div class="reservation-review-note">
                <span>Admin response</span>
                <p>@adminResponse</p>
            </div>
        </section>

        <aside class="reservation-review-panel">
            <div class="reservation-review-section-title">
                <span>03</span>
                <h2>Log</h2>
            </div>

            <ol class="reservation-status-log">
                @if (reservationActivities.Count == 0)
                {
                    <li>
                        <span>Submitted</span>
                        <strong>@createdInSkopje.ToString("dd MMM yyyy, HH:mm")</strong>
                        <p>Initial reservation request.</p>
                    </li>
                }
                else
                {
                    @foreach (var activity in reservationActivities.Take(4))
                    {
                        var activityAtUtc = DateTime.SpecifyKind(
                            activity.CreatedAtUtc,
                            DateTimeKind.Utc);

                        var activityAt = TimeZoneInfo
                            .ConvertTimeFromUtc(activityAtUtc, skopjeTimeZone)
                            .ToString("dd MMM yyyy, HH:mm");

                        <li>
                            <span>@activity.Actor / @activityAt</span>
                            <strong>@activity.Title</strong>
                            <p>@activity.Description</p>
                        </li>
                    }
                }

                <li>
                    <span>Email</span>
                    <strong>@EmailStatusLabel(Model.EmailStatus)</strong>
                    <p>@EmailStatusDetail()</p>
                </li>
            </ol>
        </aside>
    </div>

    @if (canCancel)
    {
        <section class="reservation-cancel-panel">
            <div>
                <span>Service action</span>
                <h2>Cancel Reservation</h2>
                <p>Use this when the guest calls to cancel or the booking can no longer be honored.</p>
            </div>

            <form asp-controller="AdminReservations"
                  asp-action="Cancel"
                  method="post"
                  onsubmit="return confirm('Cancel this reservation? The table will be released.');">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="id"
                       value="@Model.Id" />

                <textarea name="adminNote"
                          rows="2"
                          maxlength="500"
                          placeholder="Optional cancellation note..."></textarea>

                <button type="submit">
                    Cancel
                </button>
            </form>
        </section>
    }
</section>
