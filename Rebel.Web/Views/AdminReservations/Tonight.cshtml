@model List<Rebel.Domain.Entities.Reservation>
@using Rebel.Domain.Enums
@using System.Globalization

@{
    ViewData["Title"] = "Tonight";

    var tonightDate =
        (DateTime)(ViewBag.TonightDate ?? DateTime.Today);

    var pendingReservations = Model
        .Where(reservation =>
            reservation.Status == ReservationStatus.Pending)
        .OrderBy(reservation => reservation.ReservationTime)
        .ToList();

    var expectedReservations = Model
        .Where(reservation =>
            reservation.Status == ReservationStatus.Approved)
        .OrderBy(reservation => reservation.ReservationTime)
        .ToList();

    var completedReservations = Model
        .Where(reservation =>
            reservation.Status == ReservationStatus.Arrived ||
            reservation.Status == ReservationStatus.NoShow)
        .OrderBy(reservation => reservation.ReservationTime)
        .ToList();

    var expectedGuests = expectedReservations
        .Sum(reservation => reservation.NumberOfGuests);

    var arrivedReservations = completedReservations
        .Where(reservation =>
            reservation.Status == ReservationStatus.Arrived)
        .ToList();

    var arrivedGuests = arrivedReservations
        .Sum(reservation => reservation.NumberOfGuests);

    var slotCapacity = (int)(ViewBag.SlotCapacity ?? 40);

    var slotLoads =
        ViewBag.SlotLoads as Dictionary<TimeSpan, int>
        ?? new Dictionary<TimeSpan, int>();
}

<div class="tonight-workspace">

    <header class="tonight-workspace-header">

        <div>
            <span class="tonight-eyebrow">Live service</span>

            <h1>Tonight</h1>

            <p>
                @tonightDate.ToString(
                    "dddd, dd MMMM yyyy",
                    CultureInfo.InvariantCulture)
            </p>
        </div>

        <a asp-controller="AdminReservations"
           asp-action="Index"
           class="tonight-secondary-link">
            All reservations
        </a>

    </header>

    <section class="tonight-service-summary"
             aria-label="Tonight service summary">

        <div class="tonight-summary-item is-new">
            <span>New requests</span>
            <strong>@pendingReservations.Count</strong>
        </div>

        <div class="tonight-summary-item">
            <span>Still expected</span>
            <strong>
                @expectedReservations.Count bookings
                <small>@expectedGuests guests</small>
            </strong>
        </div>

        <div class="tonight-summary-item">
            <span>Checked in</span>
            <strong>
                @arrivedReservations.Count bookings
                <small>@arrivedGuests guests</small>
            </strong>
        </div>

    </section>

    @if (pendingReservations.Count > 0)
    {
        <a asp-controller="AdminReservations"
           asp-action="Details"
           asp-route-id="@pendingReservations[0].Id"
           class="tonight-attention">

            <span>
                @pendingReservations.Count
                @(pendingReservations.Count == 1
                    ? "new request needs"
                    : "new requests need")
                a decision.
            </span>

            <strong>Review next</strong>
        </a>
    }

    @if (slotLoads.Count > 0)
    {
        <details class="tonight-cover-load">
            <summary>
                <span>Cover load by time</span>
                <span>View</span>
            </summary>

            <div class="tonight-cover-load-grid">
                @foreach (var slot in slotLoads.OrderBy(slot => slot.Key))
                {
                    <div>
                        <strong>@slot.Key.ToString(@"hh\:mm")</strong>
                        <span>@slot.Value / @slotCapacity guests</span>
                    </div>
                }
            </div>
        </details>
    }

    @if (pendingReservations.Count > 0)
    {
        <section class="tonight-queue-section is-priority">

            <header class="tonight-queue-heading">
                <div>
                    <span class="tonight-eyebrow">Needs action</span>
                    <h2>New requests</h2>
                </div>

                <span>@pendingReservations.Count</span>
            </header>

            <div class="tonight-queue">
                @foreach (var reservation in pendingReservations)
                {
                    <partial name="_TonightReservationRow"
                             model="reservation" />
                }
            </div>

        </section>
    }

    <section class="tonight-queue-section">

        <header class="tonight-queue-heading">
            <div>
                <span class="tonight-eyebrow">Floor queue</span>
                <h2>Expected arrivals</h2>
            </div>

            <span>@expectedReservations.Count</span>
        </header>

        @if (expectedReservations.Count == 0)
        {
            <div class="tonight-empty-state">
                No approved guests are waiting to arrive.
            </div>
        }
        else
        {
            <div class="tonight-queue">
                @foreach (var reservation in expectedReservations)
                {
                    <partial name="_TonightReservationRow"
                             model="reservation" />
                }
            </div>
        }

    </section>

    @if (completedReservations.Count > 0)
    {
        <details class="tonight-completed">
            <summary>
                <span>
                    <strong>Completed</strong>
                    <small>Checked-in and closed reservations</small>
                </span>

                <span>@completedReservations.Count bookings</span>
            </summary>

            <div class="tonight-queue">
                @foreach (var reservation in completedReservations)
                {
                    <partial name="_TonightReservationRow"
                             model="reservation" />
                }
            </div>
        </details>
    }

    @if (Model.Count == 0)
    {
        <div class="tonight-empty-state is-page-empty">
            <strong>No reservations for tonight.</strong>
            <span>New requests will appear here automatically.</span>
        </div>
    }

</div>
