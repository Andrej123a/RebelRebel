@model Rebel.Domain.Entities.Event
@using Rebel.Domain.Enums

@{
    ViewData["Title"] = "Edit Event";
}

<h2 class="mb-4">Edit Event</h2>

<form asp-controller="AdminEvents" asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group mb-3">
        <label>Date</label>
        <input asp-for="Date" type="date" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Start Time</label>
        <input asp-for="StartTime" type="time" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>End Time</label>
        <input asp-for="EndTime" type="time" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Event Type</label>
        <select asp-for="EventType" class="form-control" asp-items="Html.GetEnumSelectList<EventType>()"></select>
    </div>

    <div class="form-group mb-3">
        <label>Image URL</label>
        <input asp-for="ImageUrl" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label class="form-check-label">Active</label>
    </div>

    <button type="submit" class="btn btn-warning">Save</button>
    <a asp-controller="AdminEvents" asp-action="Index" class="btn btn-secondary">Back</a>
</form>