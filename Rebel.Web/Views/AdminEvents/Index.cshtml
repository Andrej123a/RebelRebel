@model List<Rebel.Domain.Entities.Event>
@using Rebel.Domain.Enums

@{
    ViewData["Title"] = "Manage Events";

    var today = DateTime.UtcNow.Date;

    var events = Model ?? new List<Rebel.Domain.Entities.Event>();

    var tonightEvents = events
        .Where(ev => ev.Date.Date == today)
        .OrderBy(ev => ev.StartTime)
        .ToList();

    var upcomingEvents = events
        .Where(ev => ev.Date.Date > today)
        .OrderBy(ev => ev.Date)
        .ThenBy(ev => ev.StartTime)
        .ToList();

    var pastEvents = events
        .Where(ev => ev.Date.Date < today)
        .OrderByDescending(ev => ev.Date)
        .ThenByDescending(ev => ev.StartTime)
        .ToList();

    var activeEventsCount = events.Count(ev => ev.IsActive);
    var hiddenEventsCount = events.Count(ev => !ev.IsActive);

    var reservationStats =
        ViewBag.ReservationStats as Dictionary<Guid, Dictionary<string, int>>
        ?? new Dictionary<Guid, Dictionary<string, int>>();
}

@functions {
    public string FormatEventType(EventType eventType)
    {
        return eventType switch
        {
            EventType.DJNight => "DJ Night",
            EventType.BeerTasting => "Beer Tasting",
            EventType.LiveMusic => "Live Music",
            EventType.SpecialEvent => "Special Event",
            EventType.AcousticNight => "Acoustic Night",
            _ => eventType.ToString()
        };
    }

    public string FormatTimeRange(TimeSpan? startTime, TimeSpan? endTime)
    {
        if (!startTime.HasValue && !endTime.HasValue)
        {
            return "Time not specified";
        }

        if (startTime.HasValue && endTime.HasValue)
        {
            return $"{startTime.Value:hh\\:mm} – {endTime.Value:hh\\:mm}";
        }

        if (startTime.HasValue)
        {
            return $"Starts at {startTime.Value:hh\\:mm}";
        }

        return $"Ends at {endTime!.Value:hh\\:mm}";
    }

    public string GetEventTypeClass(EventType eventType)
    {
        return eventType switch
        {
            EventType.DJNight => "event-type-dj",
            EventType.BeerTasting => "event-type-beer",
            EventType.LiveMusic => "event-type-live",
            EventType.SpecialEvent => "event-type-special",
            EventType.AcousticNight => "event-type-acoustic",
            _ => "event-type-default"
        };
    }

    public string GetCapacityClass(
        Rebel.Domain.Entities.Event ev,
        int reservationsCount,
        int guestsCount)
    {
        var reservationPressure = ev.MaxReservations.HasValue
            ? (double)reservationsCount / ev.MaxReservations.Value
            : 0;

        var guestPressure = ev.MaxGuests.HasValue
            ? (double)guestsCount / ev.MaxGuests.Value
            : 0;

        var pressure = Math.Max(reservationPressure, guestPressure);

        return pressure >= 1
            ? "is-full"
            : pressure >= 0.8
                ? "is-near-capacity"
                : string.Empty;
    }

    public string GetCapacityText(
        Rebel.Domain.Entities.Event ev,
        int reservationsCount,
        int guestsCount)
    {
        if (ev.MaxGuests.HasValue &&
            guestsCount >= ev.MaxGuests.Value)
        {
            return "Guest cap reached";
        }

        if (ev.MaxReservations.HasValue &&
            reservationsCount >= ev.MaxReservations.Value)
        {
            return "Booking cap reached";
        }

        if (ev.MaxGuests.HasValue &&
            guestsCount >= ev.MaxGuests.Value * 0.8)
        {
            return $"{ev.MaxGuests.Value - guestsCount} guest seats left";
        }

        if (ev.MaxReservations.HasValue &&
            reservationsCount >= ev.MaxReservations.Value * 0.8)
        {
            return $"{ev.MaxReservations.Value - reservationsCount} bookings left";
        }

        return string.Empty;
    }
}

<div class="events-admin-page">

