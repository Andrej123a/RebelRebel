</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const eventGroups = Array.from(
                document.querySelectorAll("[data-event-group]")
            );

            eventGroups.forEach(function (group) {
                group.addEventListener("toggle", function () {
                    if (!group.open) {
                        return;
                    }

                    eventGroups.forEach(function (otherGroup) {
                        if (otherGroup !== group) {
                            otherGroup.open = false;
                        }
                    });
                });
            });
        });
    </script>
}
