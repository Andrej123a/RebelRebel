@model List<Rebel.Domain.Entities.Event>
@using Rebel.Domain.Enums

@{
    ViewData["Title"] = "Manage Events";

    var today = DateTime.UtcNow.Date;

    var events = Model ?? new List<Rebel.Domain.Entities.Event>();

    var tonightEvents = events
        .Where(ev => ev.Date.Date == today)
        .OrderBy(ev => ev.StartTime)
        .ToList();

    var upcomingEvents = events
        .Where(ev => ev.Date.Date > today)
        .OrderBy(ev => ev.Date)
        .ThenBy(ev => ev.StartTime)
        .ToList();

    var pastEvents = events
        .Where(ev => ev.Date.Date < today)
        .OrderByDescending(ev => ev.Date)
        .ThenByDescending(ev => ev.StartTime)
        .ToList();

    var activeEventsCount = events.Count(ev => ev.IsActive);
    var hiddenEventsCount = events.Count(ev => !ev.IsActive);
}

@functions {
    public string FormatEventType(EventType eventType)
    {
        return eventType switch
        {
            EventType.DJNight => "DJ Night",
            EventType.BeerTasting => "Beer Tasting",
            EventType.LiveMusic => "Live Music",
            EventType.SpecialEvent => "Special Event",
            EventType.AcousticNight => "Acoustic Night",
            _ => eventType.ToString()
        };
    }

    public string FormatTimeRange(TimeSpan? startTime, TimeSpan? endTime)
    {
        if (!startTime.HasValue && !endTime.HasValue)
        {
            return "Time not specified";
        }

        if (startTime.HasValue && endTime.HasValue)
        {
            return $"{startTime.Value:hh\\:mm} – {endTime.Value:hh\\:mm}";
        }

        if (startTime.HasValue)
        {
            return $"Starts at {startTime.Value:hh\\:mm}";
        }

        return $"Ends at {endTime!.Value:hh\\:mm}";
    }

    public string GetEventTypeClass(EventType eventType)
    {
        return eventType switch
        {
            EventType.DJNight => "event-type-dj",
            EventType.BeerTasting => "event-type-beer",
            EventType.LiveMusic => "event-type-live",
            EventType.SpecialEvent => "event-type-special",
            EventType.AcousticNight => "event-type-acoustic",
            _ => "event-type-default"
        };
    }
}

<div class="events-admin-page">

    <section class="events-admin-hero">
        <div>
            <p class="events-admin-eyebrow">
                Rebel Rebel Admin
            </p>

            <h1>Manage Events</h1>

            <p class="events-admin-description">
                Create, update and manage upcoming Rebel Rebel nights.
            </p>
        </div>

        <a asp-controller="AdminEvents"
           asp-action="Create"
           class="events-add-button">
            <span>+</span>
            Add Event
        </a>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="events-success-message"
             role="alert">

            <div>
                <small>Control room signal</small>
                <strong>@TempData["SuccessMessage"]</strong>
            </div>

            <button type="button"
                    data-bs-dismiss="alert"
                    aria-label="Close">
                ×
            </button>
        </div>
    }

    @if (events.Any())
    {
        <section class="events-inventory-stats">

            <div class="events-stat events-stat-main">
                <span>Total events</span>
                <strong>@events.Count</strong>
                <small>Complete event archive</small>
            </div>

            <div class="events-stat events-stat-tonight">
                <span>Tonight</span>
                <strong>@tonightEvents.Count</strong>
                <small>Happening today</small>
            </div>

            <div class="events-stat events-stat-upcoming">
                <span>Upcoming</span>
                <strong>@upcomingEvents.Count</strong>
                <small>Scheduled nights</small>
            </div>

            <div class="events-stat events-stat-hidden">
                <span>Hidden</span>
                <strong>@hiddenEventsCount</strong>
                <small>@activeEventsCount active events</small>
            </div>

        </section>

        <section class="events-groups">

            @if (tonightEvents.Any())
            {
                <details class="events-group events-group-tonight"
                         data-event-group
                         open>

                    <summary class="events-group-summary">
                        <span class="events-group-number">01</span>

                        <span class="events-group-copy">
                            <small>Live schedule</small>
                            <strong>Tonight</strong>
                        </span>

                        <span class="events-group-count">
                            @tonightEvents.Count
                            @(tonightEvents.Count == 1 ? "event" : "events")
                        </span>

                        <span class="events-group-toggle">
                            <span class="events-group-open">Open</span>
                            <span class="events-group-close">Close</span>
                            <i></i>
                        </span>
                    </summary>

                    <div class="events-group-content">

                        <div class="events-list-heading">
                            <span>Event</span>
                            <span>Date and time</span>
                            <span>Status</span>
                            <span>Actions</span>
                        </div>

                        @foreach (var ev in tonightEvents)
                        {
                            <article class="events-list-row">

                                <div class="events-row-main">
                                    <div class="events-row-image">
                                        @if (!string.IsNullOrWhiteSpace(ev.ImageUrl))
                                        {
                                            <img src="@Url.Content(ev.ImageUrl)"
                                                 alt="@ev.Title"
                                                 loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="events-row-placeholder">
                                                <span>✦</span>
                                                <small>Event</small>
                                            </div>
                                        }
                                </div>

                                <div class="events-row-copy">
                                    <span class="events-type @GetEventTypeClass(ev.EventType)">
                                        @FormatEventType(ev.EventType)
                                    </span>

                                    <strong>@ev.Title</strong>

                                    <p>
                                        @(string.IsNullOrWhiteSpace(ev.Description)
                                                                        ? "No description available."
                                                                        : ev.Description)
                            </p>
                        </div>
                    </div>

                                <div class="events-row-date">
                                    <small>Date and time</small>

                                    <strong>
                                        @ev.Date.ToString("dd MMM yyyy")
                                    </strong>

                                    <span>
                                        @FormatTimeRange(ev.StartTime, ev.EndTime)
                                    </span>
                                </div>

                                <div class="events-row-status">
                                    <small>Status</small>

                        @if (ev.IsActive)
                                    {
                                        <span class="events-status active">
                                            <i></i>
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="events-status hidden">
                                            <i></i>
                                            Hidden
                                        </span>
                                    }

                                    <span class="events-period tonight">
                                        Tonight
                                    </span>
                                </div>

                                <div class="events-row-actions-wrap">
                                    <details class="events-row-actions">
                                        <summary aria-label="Actions for @ev.Title">
                                            <span></span>
                                            <span></span>
                                            <span></span>
                                        </summary>

                                        <div class="events-row-actions-menu">

                                            @if (ev.IsActive)
                                            {
                                                <a asp-controller="Events"
                                                   asp-action="Details"
                                                   asp-route-id="@ev.Id">
                                                    <strong>View</strong>
                                                    <small>Open public event</small>
                                                </a>
                                            }

                                            <a asp-controller="AdminEvents"
                                               asp-action="Edit"
                                               asp-route-id="@ev.Id">
                                                <strong>Edit</strong>
                                                <small>Update event</small>
                                            </a>

                                            <a asp-controller="AdminEvents"
                                               asp-action="Delete"
                                               asp-route-id="@ev.Id"
                                               class="danger">
                                                <strong>Delete</strong>
                                                <small>Remove event</small>
                                            </a>

                                        </div>
                                    </details>
                                </div>

                            </article>
                        }

                    </div>
                </details>
            }

            @if (upcomingEvents.Any())
            {
                <details class="events-group"
                         data-event-group
                         @(tonightEvents.Any() ? null : "open")>

                    <summary class="events-group-summary">
                        <span class="events-group-number">
                            @(tonightEvents.Any() ? "02" : "01")
                        </span>

                        <span class="events-group-copy">
                            <small>Future schedule</small>
                            <strong>Upcoming</strong>
                        </span>

                        <span class="events-group-count">
                            @upcomingEvents.Count
                            @(upcomingEvents.Count == 1 ? "event" : "events")
                        </span>

                        <span class="events-group-toggle">
                            <span class="events-group-open">Open</span>
                            <span class="events-group-close">Close</span>
                            <i></i>
                        </span>
                    </summary>

                    <div class="events-group-content">

                        <div class="events-list-heading">
                            <span>Event</span>
                            <span>Date and time</span>
                            <span>Status</span>
                            <span>Actions</span>
                        </div>

                        @foreach (var ev in upcomingEvents)
                        {
                            <article class="events-list-row">

                                <div class="events-row-main">
                                    <div class="events-row-image">
                                        @if (!string.IsNullOrWhiteSpace(ev.ImageUrl))
                                        {
                                            <img src="@Url.Content(ev.ImageUrl)"
                                                 alt="@ev.Title"
                                                 loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="events-row-placeholder">
                                                <span>✦</span>
                                                <small>Event</small>
                                            </div>
                                        }
                                </div>

                                <div class="events-row-copy">
                                    <span class="events-type @GetEventTypeClass(ev.EventType)">
                                        @FormatEventType(ev.EventType)
                                    </span>

                                    <strong>@ev.Title</strong>

                                    <p>
                                        @(string.IsNullOrWhiteSpace(ev.Description)
                                                                        ? "No description available."
                                                                        : ev.Description)
                            </p>
                        </div>
                    </div>

                                <div class="events-row-date">
                                    <small>Date and time</small>

                                    <strong>
                                        @ev.Date.ToString("dd MMM yyyy")
                                    </strong>

                                    <span>
                                        @FormatTimeRange(ev.StartTime, ev.EndTime)
                                    </span>
                                </div>

                                <div class="events-row-status">
                                    <small>Status</small>

                        @if (ev.IsActive)
                                    {
                                        <span class="events-status active">
                                            <i></i>
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="events-status hidden">
                                            <i></i>
                                            Hidden
                                        </span>
                                    }

                                    <span class="events-period upcoming">
                                        Upcoming
                                    </span>
                                </div>

                                <div class="events-row-actions-wrap">
                                    <details class="events-row-actions">
                                        <summary aria-label="Actions for @ev.Title">
                                            <span></span>
                                            <span></span>
                                            <span></span>
                                        </summary>

                                        <div class="events-row-actions-menu">

                                            @if (ev.IsActive)
                                            {
                                                <a asp-controller="Events"
                                                   asp-action="Details"
                                                   asp-route-id="@ev.Id">
                                                    <strong>View</strong>
                                                    <small>Open public event</small>
                                                </a>
                                            }

                                            <a asp-controller="AdminEvents"
                                               asp-action="Edit"
                                               asp-route-id="@ev.Id">
                                                <strong>Edit</strong>
                                                <small>Update event</small>
                                            </a>

                                            <a asp-controller="AdminEvents"
                                               asp-action="Delete"
                                               asp-route-id="@ev.Id"
                                               class="danger">
                                                <strong>Delete</strong>
                                                <small>Remove event</small>
                                            </a>

                                        </div>
                                    </details>
                                </div>

                            </article>
                        }

                    </div>
                </details>
            }

            @if (pastEvents.Any())
            {
                var pastGroupNumber = 1;

                if (tonightEvents.Any())
                {
                    pastGroupNumber++;
                }

                if (upcomingEvents.Any())
                {
                    pastGroupNumber++;
                }

                <details class="events-group events-group-past"
                         data-event-group>

                    <summary class="events-group-summary">
                        <span class="events-group-number">
                            @pastGroupNumber.ToString("00")
                        </span>

                        <span class="events-group-copy">
                            <small>Event archive</small>
                            <strong>Past Events</strong>
                        </span>

                        <span class="events-group-count">
                            @pastEvents.Count
                            @(pastEvents.Count == 1 ? "event" : "events")
                        </span>

                        <span class="events-group-toggle">
                            <span class="events-group-open">Open</span>
                            <span class="events-group-close">Close</span>
                            <i></i>
                        </span>
                    </summary>

                    <div class="events-group-content">

                        <div class="events-list-heading">
                            <span>Event</span>
                            <span>Date and time</span>
                            <span>Status</span>
                            <span>Actions</span>
                        </div>

                        @foreach (var ev in pastEvents)
                        {
                            <article class="events-list-row is-past">

                                <div class="events-row-main">
                                    <div class="events-row-image">
                                        @if (!string.IsNullOrWhiteSpace(ev.ImageUrl))
                                        {
                                            <img src="@Url.Content(ev.ImageUrl)"
                                                 alt="@ev.Title"
                                                 loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="events-row-placeholder">
                                                <span>✦</span>
                                                <small>Event</small>
                                            </div>
                                        }
                                </div>

                                <div class="events-row-copy">
                                    <span class="events-type @GetEventTypeClass(ev.EventType)">
                                        @FormatEventType(ev.EventType)
                                    </span>

                                    <strong>@ev.Title</strong>

                                    <p>
                                        @(string.IsNullOrWhiteSpace(ev.Description)
                                                                        ? "No description available."
                                                                        : ev.Description)
                            </p>
                        </div>
                    </div>

                                <div class="events-row-date">
                                    <small>Date and time</small>

                                    <strong>
                                        @ev.Date.ToString("dd MMM yyyy")
                                    </strong>

                                    <span>
                                        @FormatTimeRange(ev.StartTime, ev.EndTime)
                                    </span>
                                </div>

                                <div class="events-row-status">
                                    <small>Status</small>

                        @if (ev.IsActive)
                                    {
                                        <span class="events-status active">
                                            <i></i>
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="events-status hidden">
                                            <i></i>
                                            Hidden
                                        </span>
                                    }

                                    <span class="events-period past">
                                        Past event
                                    </span>
                                </div>

                                <div class="events-row-actions-wrap">
                                    <details class="events-row-actions">
                                        <summary aria-label="Actions for @ev.Title">
                                            <span></span>
                                            <span></span>
                                            <span></span>
                                        </summary>

                                        <div class="events-row-actions-menu">

                                            <a asp-controller="AdminEvents"
                                               asp-action="Edit"
                                               asp-route-id="@ev.Id">
                                                <strong>Edit</strong>
                                                <small>Update event</small>
                                            </a>

                                            <a asp-controller="AdminEvents"
                                               asp-action="Delete"
                                               asp-route-id="@ev.Id"
                                               class="danger">
                                                <strong>Delete</strong>
                                                <small>Remove event</small>
                                            </a>

                                        </div>
                                    </details>
                                </div>

                            </article>
                        }

                    </div>
                </details>
            }

        </section>
    }
    else
    {
        <section class="events-empty-state">
            <span class="events-empty-symbol">✦</span>

            <div>
                <p>No event signal</p>

                <h2>No events created yet</h2>

                <span>
                    Create the first Rebel Rebel night and it will appear on the public Events page.
                </span>

                <a asp-controller="AdminEvents"
                   asp-action="Create">
                    + Create First Event
                </a>
            </div>
        </section>
    }

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const eventGroups = Array.from(
                document.querySelectorAll("[data-event-group]")
            );

            eventGroups.forEach(function (group) {
                group.addEventListener("toggle", function () {
                    if (!group.open) {
                        return;
                    }

                    eventGroups.forEach(function (otherGroup) {
                        if (otherGroup !== group) {
                            otherGroup.open = false;
                        }
                    });
                });
            });

            document.addEventListener("click", function (event) {
                const clickedActionMenu =
                    event.target.closest(".events-row-actions");

                document
                    .querySelectorAll(".events-row-actions[open]")
                    .forEach(function (menu) {
                        if (menu !== clickedActionMenu) {
                            menu.removeAttribute("open");
                        }
                    });
            });
        });
    </script>
}