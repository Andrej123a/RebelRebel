@model List<Rebel.Domain.Entities.Reservation>
@using Rebel.Domain.Entities
@using Rebel.Domain.Enums

@{
    var eventItem = ViewBag.Event as Event
        ?? throw new InvalidOperationException("Event is required.");

    ViewData["Title"] = $"{eventItem.Title} Bookings";

    var activeReservations = Model
        .Where(reservation =>
            reservation.Status != ReservationStatus.Rejected &&
            reservation.Status != ReservationStatus.NoShow &&
            reservation.Status != ReservationStatus.Cancelled)
        .ToList();

    var guestCount = activeReservations
        .Sum(reservation => reservation.NumberOfGuests);

    var pendingCount = Model.Count(reservation =>
        reservation.Status == ReservationStatus.Pending);

    var arrivedCount = Model.Count(reservation =>
        reservation.Status == ReservationStatus.Arrived);
}

<div class="admin-workspace">

    <header class="admin-workspace-header">
        <div class="admin-workspace-heading">
            <a asp-controller="AdminEvents"
               asp-action="Index"
               class="admin-workspace-eyebrow">
                Back to events
            </a>

            <h1 class="admin-workspace-title">
                @eventItem.Title
            </h1>

            <p class="admin-workspace-copy">
                @eventItem.Date.ToString("dddd, dd MMM yyyy")
                @(eventItem.StartTime.HasValue
                    ? $" at {eventItem.StartTime.Value:hh\\:mm}"
                    : "")
            </p>
        </div>

        <div class="admin-workspace-actions">
            <a asp-controller="AdminReservations"
               asp-action="Index"
               asp-route-eventId="@eventItem.Id"
               class="admin-primary-button">
                Reservation board
            </a>

            <a asp-controller="AdminEvents"
               asp-action="Edit"
               asp-route-id="@eventItem.Id"
               class="admin-secondary-button">
                Edit event
            </a>
        </div>
    </header>

    <section class="admin-metric-bar"
             aria-label="Event booking summary">
        <div class="admin-metric">
            <span>Bookings</span>
            <strong>@activeReservations.Count</strong>
        </div>

        <div class="admin-metric">
            <span>Guests</span>
            <strong>
                @guestCount
                @if (eventItem.MaxGuests.HasValue)
                {
                    <small>/ @eventItem.MaxGuests.Value</small>
                }
            </strong>
        </div>

        <div class="admin-metric @(pendingCount > 0 ? "is-attention" : "")">
            <span>New requests</span>
            <strong>@pendingCount</strong>
        </div>
    </section>

    @if (Model.Count == 0)
    {
        <div class="admin-empty-state">
            <strong>No event bookings yet.</strong>
            <span>Reservations made from this event will appear here.</span>
        </div>
    }
    else
    {
        <section class="admin-section">
            <header class="admin-section-heading">
                <div>
                    <span class="admin-workspace-eyebrow">
                        Guest list
                    </span>
                    <h2>Reservations</h2>
                </div>

                <span class="admin-section-count">@Model.Count</span>
            </header>

            <div class="admin-list">
                @foreach (var reservation in Model
                    .OrderBy(reservation => reservation.ReservationTime))
                {
                    <partial name="~/Views/AdminReservations/_ReservationDeskRow.cshtml"
                             model="reservation" />
                }
            </div>
        </section>
    }

</div>
