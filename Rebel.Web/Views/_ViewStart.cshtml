@{
    var controller =
        ViewContext.RouteData.Values["controller"]?.ToString();

    var isAdminSection =
        controller == "Admin" ||
        controller == "AdminEvents" ||
        controller == "AdminReservations" ||
        controller == "AdminTables" ||
        controller == "Category" ||
        controller == "Product";

    Layout = isAdminSection
        ? "_AdminLayout"
        : "_Layout";
}
