@model ErrorViewModel

@{
    ViewData["Title"] = "Something went wrong";
    ViewData["MetaDescription"] = "Rebel Rebel by Fat Kitchen could not load this page. Return home, view the menu, or book a table.";
}

<section class="rr-error-page">
    <div class="rr-error-panel">
        <p>Signal lost</p>

        <h1>Something went sideways.</h1>

        <span>
            The page could not be loaded right now. Try again, or head back to the main Rebel Rebel by Fat Kitchen pages.
        </span>

        <div class="rr-error-actions">
            <a asp-controller="Home"
               asp-action="Index">
                Back Home
            </a>

            <a asp-controller="Home"
               asp-action="Menu">
                View Menu
            </a>

            <a asp-controller="Reservations"
               asp-action="Create">
                Book a Table
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <small>
                Reference: @Model.RequestId
            </small>
        }
    </div>
</section>
