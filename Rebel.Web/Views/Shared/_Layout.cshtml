@{
    var currentController =
        ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    var currentAction =
        ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string IsActive(string controller, string? action = null)
    {
        var controllerMatches =
            currentController.Equals(
                controller,
                StringComparison.OrdinalIgnoreCase
            );

        var actionMatches =
            string.IsNullOrWhiteSpace(action) ||
            currentAction.Equals(
                action,
                StringComparison.OrdinalIgnoreCase
            );

        return controllerMatches && actionMatches
            ? "active"
            : "";
    }
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Rebel Rebel</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/Rebel.Web.styles.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/home.css"
          asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />
</head>

<body>

    <header class="rr-site-header">

        <nav class="rr-site-nav">

            <div class="rr-nav-container">

                <a asp-controller="Home"
                   asp-action="Index"
                   class="rr-site-brand">

                    <span class="rr-brand-image-frame">

                        <img src="~/images/email/rebel-logo.png"
                             alt="Rebel Rebel"
                             class="rr-brand-image" />

                    </span>

                    <span class="rr-brand-text">

                        <small>
                            Skopje / After dark
                        </small>

                        <strong>
                            Rebel Rebel by Fat Kitchen
                        </strong>

                    </span>

                </a>

                <button class="rr-nav-toggle"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#rebelNavigation"
                        aria-controls="rebelNavigation"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span></span>
                    <span></span>
                    <span></span>

                    <small>
                        MENU
                    </small>

                </button>

                <div class="collapse rr-nav-collapse"
                     id="rebelNavigation">

                    <div class="rr-navigation">

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="rr-nav-link @IsActive("Home", "Index")">

                            <span class="rr-nav-index">
                                01
                            </span>

                            <span class="rr-nav-name">
                                Home
                            </span>

                        </a>

                        <a asp-controller="Home"
                           asp-action="Menu"
                           asp-route-section="food"
                           class="rr-nav-link @IsActive("Home", "Menu")">

                            <span class="rr-nav-index">
                                02
                            </span>

                            <span class="rr-nav-name">
                                Menu
                            </span>

                        </a>

                        <a asp-controller="Events"
                           asp-action="Index"
                           class="rr-nav-link @IsActive("Events")">

                            <span class="rr-nav-index">
                                03
                            </span>

                            <span class="rr-nav-name">
                                Events
                            </span>

                        </a>

                        <a asp-controller="Home"
                           asp-action="Contact"
                           class="rr-nav-link @IsActive("Home", "Contact")">

                            <span class="rr-nav-index">
                                04
                            </span>

                            <span class="rr-nav-name">
                                Contact
                            </span>

                        </a>

                    </div>

                    <a asp-controller="Reservations"
                       asp-action="Create"
                       class="rr-nav-reserve @IsActive("Reservations")">

                        <span class="rr-reserve-label">
                            Secure your spot
                        </span>

                        <strong>
                            Book a Table
                        </strong>

                        <span class="rr-reserve-arrow">
                            ↗
                        </span>

                    </a>

                </div>

            </div>

            <div class="rr-nav-warning-strip">

                <div class="rr-nav-warning-track">

                    <span>No boring nights</span>
                    <i>✦</i>

                    <span>Rare beer</span>
                    <i>✦</i>

                    <span>Bold food</span>
                    <i>✦</i>

                    <span>Alternative sound</span>
                    <i>✦</i>

                    <span>No boring nights</span>
                    <i>✦</i>

                    <span>Rare beer</span>

                </div>

            </div>

        </nav>

    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="rr-site-footer">

        <div class="rr-footer-container">

            <div class="rr-footer-brand">

                <span>
                    Rebel Rebel
                </span>

                <strong>
                    No boring nights.
                </strong>

            </div>

            <div class="rr-footer-copy">
                © 2026 Rebel Rebel · Skopje
            </div>

            <a asp-controller="Reservations"
               asp-action="Create"
               class="rr-footer-link">

                Book a table ↗
            </a>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>