@using Microsoft.EntityFrameworkCore
@inject Rebel.Infrastructure.Data.AppDbContext DbContext

@{
    var currentController =
        ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;

    var currentAction =
        ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    var unreadNotificationsCount = await DbContext.Notifications
        .AsNoTracking()
        .CountAsync(notification =>
            !notification.IsRead &&
            notification.ReservationId.HasValue &&
            notification.Reservation != null &&
            notification.Reservation.Status ==
                Rebel.Domain.Enums.ReservationStatus.Pending);

    var latestUnreadReservationId = await DbContext.Notifications
        .AsNoTracking()
        .Where(notification =>
            !notification.IsRead &&
            notification.ReservationId.HasValue &&
            notification.Reservation != null &&
            notification.Reservation.Status ==
                Rebel.Domain.Enums.ReservationStatus.Pending)
        .OrderByDescending(notification => notification.CreatedAt)
        .Select(notification => notification.ReservationId)
        .FirstOrDefaultAsync();

    var displayedNotificationCount = unreadNotificationsCount > 99
        ? "99+"
        : unreadNotificationsCount.ToString();

    var reservationSignalAction =
        unreadNotificationsCount == 1 &&
        latestUnreadReservationId.HasValue
            ? "Details"
            : "Index";

    var reservationSignalRouteValues = new Dictionary<string, string?>();

    if (unreadNotificationsCount == 1 &&
        latestUnreadReservationId.HasValue)
    {
        reservationSignalRouteValues["id"] =
            latestUnreadReservationId.Value.ToString();
    }
    else if (unreadNotificationsCount > 1)
    {
        reservationSignalRouteValues["status"] = "Pending";
    }

    string GetActiveClass(string controllerName)
    {
        return currentController == controllerName
            ? "active"
            : string.Empty;
    }

    string GetCommandActiveClass(
        string controllerName,
        string actionName)
    {
        return currentController == controllerName &&
               currentAction == actionName
            ? "active"
            : string.Empty;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] — Rebel Control Room</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/admin.css"
          asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />
</head>

<body class="admin-shell-body">

    <div class="admin-shell">

        <aside class="admin-rail">

            <div class="admin-rail-header">

                <a asp-controller="Admin"
                   asp-action="Index"
                   class="admin-brand">

                    <span class="admin-brand-kicker">
                        Private access
                    </span>

                    <span class="admin-brand-name">
                        REBEL<br />
                        CONTROL<br />
                        ROOM
                    </span>

                </a>

                <button class="admin-mobile-toggle"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#adminNavigation"
                        aria-controls="adminNavigation"
                        aria-expanded="false"
                        aria-label="Toggle admin navigation">

                    MENU
                </button>

            </div>

            <div class="collapse d-lg-block"
                 id="adminNavigation">

                <nav class="admin-navigation">

                    <a asp-controller="Admin"
                       asp-action="Index"
                       class="admin-nav-link @GetActiveClass("Admin")">

                        <span class="admin-nav-number">01</span>
                        <span>Dashboard</span>
                    </a>

                    <a asp-controller="AdminReservations"
                       asp-action="Index"
                       class="admin-nav-link @GetActiveClass("AdminReservations")">

                        <span class="admin-nav-number">02</span>
                        <span>Reservation Desk</span>

                        <span id="reservationNavBadge"
                              class="admin-nav-alert @(unreadNotificationsCount > 0 ? string.Empty : "d-none")"
                              aria-label="@unreadNotificationsCount unread reservation notifications">
                            @displayedNotificationCount
                        </span>

                    </a>

                    <div class="admin-subnav"
                         aria-label="Reservation shortcuts">
                        <a asp-controller="AdminReservations"
                           asp-action="Tonight"
                           class="@GetCommandActiveClass("AdminReservations", "Tonight")">
                            Tonight
                        </a>

                        <a asp-controller="AdminReservations"
                           asp-action="Planner"
                           class="@GetCommandActiveClass("AdminReservations", "Planner")">
                            Week Planner
                        </a>
                    </div>

                    <a asp-controller="AdminEvents"
                       asp-action="Index"
                       class="admin-nav-link @GetActiveClass("AdminEvents")">

                        <span class="admin-nav-number">03</span>
                        <span>Gig Calendar</span>
                    </a>

                    <a asp-controller="Product"
                       asp-action="Index"
                       class="admin-nav-link @GetActiveClass("Product")">

                        <span class="admin-nav-number">04</span>
                        <span>Menu Board</span>
                    </a>

                    <a asp-controller="Category"
                       asp-action="Index"
                       class="admin-nav-link @GetActiveClass("Category")">

                        <span class="admin-nav-number">05</span>
                        <span>Menu Sections</span>
                    </a>

                    <a asp-controller="AdminTables"
                       asp-action="Index"
                       class="admin-nav-link @GetActiveClass("AdminTables")">

                        <span class="admin-nav-number">06</span>
                        <span>Floor Plan</span>
                    </a>

                    <a asp-controller="AdminArchive"
                       asp-action="Index"
                       class="admin-nav-link @GetActiveClass("AdminArchive")">

                        <span class="admin-nav-number">07</span>
                        <span>Archive</span>
                    </a>

                </nav>

                <div class="admin-rail-footer">

                    <div class="admin-user-block">
                        <span class="admin-user-label">
                            Signed in as
                        </span>

                        <strong>
                            @User.Identity?.Name
                        </strong>
                    </div>

                    <a asp-controller="Home"
                       asp-action="Index"
                       target="_blank"
                       class="admin-view-site">

                        View website
                    </a>

                    <form asp-area="Identity"
                          asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home")"
                          method="post">

                        <button type="submit"
                                class="admin-logout-button">

                            Log out
                        </button>

                    </form>

                </div>

            </div>

        </aside>

        <main class="admin-stage">

            <div class="admin-stage-topline">

                <span>
                    Rebel Rebel by Fat Kitchen / Internal system
                </span>

                <div class="admin-topline-actions">

                    <a id="reservationSignal"
                       asp-controller="AdminReservations"
                       asp-action="@reservationSignalAction"
                       asp-all-route-data="@reservationSignalRouteValues"
                       class="admin-reservation-signal @(unreadNotificationsCount > 0 ? "has-notifications" : string.Empty)"
                       aria-label="Open reservation notifications">

                        <span class="admin-signal-icon"
                              aria-hidden="true">

                            <svg viewBox="0 0 24 24"
                                 fill="none"
                                 xmlns="http://www.w3.org/2000/svg">

                                <path d="M18 8A6 6 0 0 0 6 8C6 15 3 15 3 17H21C21 15 18 15 18 8Z"
                                      stroke-width="1.8"
                                      stroke-linecap="square"
                                      stroke-linejoin="miter" />

                                <path d="M9.75 20H14.25"
                                      stroke-width="1.8"
                                      stroke-linecap="square" />

                            </svg>

                        </span>

                        <span class="admin-signal-copy">

                            <span class="admin-signal-label">
                                TABLE SIGNAL
                            </span>

                            <span id="reservationSignalState"
                                  class="admin-signal-state">

                                @(unreadNotificationsCount > 0
                                                                ? "NEW REQUEST"
                                                                : "ALL CLEAR")

                            </span>

                        </span>

                        <span id="notificationBadge"
                              class="admin-signal-count @(unreadNotificationsCount > 0 ? string.Empty : "d-none")">

                            @displayedNotificationCount

                        </span>

                    </a>

                    <span class="admin-live-mark">
                        SYSTEM ONLINE
                    </span>

                </div>

            </div>

            @if (TempData["SuccessMessage"] != null ||
                 TempData["ErrorMessage"] != null)
            {
                <div class="admin-system-signals"
                     aria-live="polite">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="admin-system-signal success"
                             role="status">
                            <span>OK</span>

                            <div>
                                <small>Control room update</small>
                                <strong>@TempData["SuccessMessage"]</strong>
                            </div>

                            <button type="button"
                                    aria-label="Dismiss message"
                                    data-admin-dismiss-signal>
                                Close
                            </button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="admin-system-signal danger"
                             role="alert">
                            <span>!</span>

                            <div>
                                <small>Needs attention</small>
                                <strong>@TempData["ErrorMessage"]</strong>
                            </div>

                            <button type="button"
                                    aria-label="Dismiss message"
                                    data-admin-dismiss-signal>
                                Close
                            </button>
                        </div>
                    }
                </div>
            }

            <div class="admin-page-frame">
                @RenderBody()
            </div>

        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

    <script src="~/js/admin-notifications.js"
            asp-append-version="true"></script>

    <script>
        (() => {
            document.addEventListener("submit", (event) => {
                const form = event.target;

                if (!(form instanceof HTMLFormElement)) {
                    return;
                }

                if (form.classList.contains("product-status-form")) {
                    return;
                }

                if (form.dataset.submitting === "true") {
                    event.preventDefault();
                    return;
                }

                form.dataset.submitting = "true";

                window.setTimeout(() => {
                    form
                        .querySelectorAll("button[type='submit']")
                        .forEach((button) => {
                            button.setAttribute("disabled", "disabled");
                    });
                }, 0);
            });

            document.addEventListener("click", (event) => {
                const dismissButton =
                    event.target.closest("[data-admin-dismiss-signal]");

                if (!dismissButton) {
                    return;
                }

                dismissButton
                    .closest(".admin-system-signal")
                    ?.remove();
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
