</style>

<script>
    (() => {
        const carousel = document.getElementById("rebel3dEvents");

        if (!carousel) {
            return;
        }

        const stage = carousel.querySelector(".rebel-3d-stage");
        const slides = Array.from(carousel.querySelectorAll(".rebel-3d-slide"));
        const dots = Array.from(carousel.querySelectorAll("[data-rebel-dot]"));
        const previousButton = carousel.querySelector("[data-rebel-prev]");
        const nextButton = carousel.querySelector("[data-rebel-next]");
        const status = carousel.querySelector(".rebel-3d-status");

        if (!stage || slides.length === 0) {
            return;
        }

        let activeIndex = 0;
        let pointerId = null;
        let startX = 0;
        let currentX = 0;
        let startTime = 0;
        let hasDragged = false;
        let suppressClick = false;

        const wrapIndex = (index) => {
            return (index + slides.length) % slides.length;
        };

        const getCircularOffset = (index) => {
            let offset = index - activeIndex;

            if (slides.length > 2) {
                const half = slides.length / 2;

                if (offset > half) {
                    offset -= slides.length;
                }
                else if (offset < -half) {
                    offset += slides.length;
                }
            }

            return offset;
        };

        const render = (dragX = 0) => {
            const stageWidth = stage.clientWidth || window.innerWidth;
            const desktop = window.matchMedia("(min-width: 768px)").matches;
            const spacing = desktop
                ? Math.min(stageWidth * 0.48, 560)
                : Math.min(stageWidth * 0.72, 330);

            const dragPosition = spacing === 0 ? 0 : dragX / spacing;

            slides.forEach((slide, index) => {
                const baseOffset = getCircularOffset(index);
                const position = baseOffset + dragPosition;
                const distance = Math.abs(position);
                const translateX = position * spacing;
                const translateZ = 85 - Math.min(distance, 3) * (desktop ? 250 : 190);
                const rotateY = Math.max(-68, Math.min(68, position * -34));
                const scale = Math.max(0.72, 1 - distance * (desktop ? 0.095 : 0.08));
                const opacity = distance > 2.55 ? 0 : Math.max(0.18, 1 - distance * 0.24);
                const blur = distance > 1.55 ? Math.min(2.2, (distance - 1.55) * 1.4) : 0;
                const isActive = index === activeIndex;
                const isVisible = distance <= 2.55;

                slide.style.transform = `translate3d(calc(-50% + ${translateX}px), -50%, ${translateZ}px) rotateY(${rotateY}deg) scale(${scale})`;
                slide.style.opacity = opacity.toString();
                slide.style.filter = `brightness(${Math.max(0.52, 1 - distance * 0.17)}) blur(${blur}px)`;
                slide.style.zIndex = String(120 - Math.round(distance * 20));

                slide.classList.toggle("is-active", isActive);
                slide.classList.toggle("is-visible", isVisible);
                slide.setAttribute("aria-hidden", isActive ? "false" : "true");

                slide.querySelectorAll("a, button").forEach((interactiveElement) => {
                    interactiveElement.tabIndex = isActive ? 0 : -1;
                });
            });

            dots.forEach((dot, index) => {
                const isActive = index === activeIndex;
                dot.classList.toggle("is-active", isActive);
                dot.setAttribute("aria-current", isActive ? "true" : "false");
            });

            if (status) {
                status.textContent = `${String(activeIndex + 1).padStart(2, "0")} / ${String(slides.length).padStart(2, "0")}`;
            }
        };

        const goTo = (index) => {
            activeIndex = wrapIndex(index);
            render();
        };

        const goNext = () => goTo(activeIndex + 1);
        const goPrevious = () => goTo(activeIndex - 1);

        previousButton?.addEventListener("click", goPrevious);
        nextButton?.addEventListener("click", goNext);

        dots.forEach((dot) => {
            dot.addEventListener("click", () => {
                goTo(Number(dot.dataset.rebelDot));
            });
        });

        slides.forEach((slide, index) => {
            slide.addEventListener("click", (event) => {
                if (suppressClick) {
                    event.preventDefault();
                    event.stopPropagation();
                    return;
                }

                if (index !== activeIndex) {
                    event.preventDefault();
                    goTo(index);
                }
            });
        });

        stage.addEventListener("pointerdown", (event) => {
            if (slides.length < 2 || (event.pointerType === "mouse" && event.button !== 0)) {
                return;
            }

            pointerId = event.pointerId;
            startX = event.clientX;
            currentX = event.clientX;
            startTime = performance.now();
            hasDragged = false;

            carousel.classList.add("is-dragging");
            stage.setPointerCapture(pointerId);
        });

        stage.addEventListener("pointermove", (event) => {
            if (pointerId !== event.pointerId) {
                return;
            }

            currentX = event.clientX;
            const deltaX = currentX - startX;

            if (Math.abs(deltaX) > 6) {
                hasDragged = true;
            }

            render(deltaX * 0.92);
        });

        const finishDrag = (event) => {
            if (pointerId === null || event.pointerId !== pointerId) {
                return;
            }

            const deltaX = currentX - startX;
            const elapsed = Math.max(1, performance.now() - startTime);
            const velocity = deltaX / elapsed;
            const threshold = Math.min(105, stage.clientWidth * 0.13);

            if (hasDragged && (deltaX < -threshold || velocity < -0.55)) {
                goNext();
            }
            else if (hasDragged && (deltaX > threshold || velocity > 0.55)) {
                goPrevious();
            }
            else {
                render();
            }

            if (hasDragged) {
                suppressClick = true;
                window.setTimeout(() => {
                    suppressClick = false;
                }, 80);
            }

            carousel.classList.remove("is-dragging");

            if (stage.hasPointerCapture(pointerId)) {
                stage.releasePointerCapture(pointerId);
            }

            pointerId = null;
        };

        stage.addEventListener("pointerup", finishDrag);
        stage.addEventListener("pointercancel", finishDrag);

        carousel.addEventListener("keydown", (event) => {
            if (event.key === "ArrowRight") {
                event.preventDefault();
                goNext();
            }
            else if (event.key === "ArrowLeft") {
                event.preventDefault();
                goPrevious();
            }
        });

        let wheelLocked = false;

        stage.addEventListener("wheel", (event) => {
            const horizontalIntent = Math.abs(event.deltaX) > Math.abs(event.deltaY) || event.shiftKey;

            if (!horizontalIntent || wheelLocked || slides.length < 2) {
                return;
            }

            event.preventDefault();
            wheelLocked = true;

            if ((event.deltaX || event.deltaY) > 0) {
                goNext();
            }
            else {
                goPrevious();
            }

            window.setTimeout(() => {
                wheelLocked = false;
            }, 420);
        }, { passive: false });

        window.addEventListener("resize", () => render());
        render();
    })();
</script>

