@model List<Rebel.Domain.Entities.Event>
@using System.Globalization

@{
    ViewData["Title"] = "Events";

    var events = Model ?? new List<Rebel.Domain.Entities.Event>();

    var nextEvent = events
        .OrderBy(e => e.Date)
        .ThenBy(e => e.StartTime)
        .FirstOrDefault();
}

@functions {
    public string FormatEventDate(DateTime date)
    {
        var skopjeTimeZone = TimeZoneInfo.FindSystemTimeZoneById("Europe/Skopje");

        var today = TimeZoneInfo
            .ConvertTimeFromUtc(DateTime.UtcNow, skopjeTimeZone)
            .Date;

        var eventDate = date.Date;

        if (eventDate == today)
            return "Tonight";

        if (eventDate == today.AddDays(1))
            return "Tomorrow";

        if (eventDate > today && eventDate <= today.AddDays(7))
            return $"This {eventDate.ToString("dddd", CultureInfo.InvariantCulture)}";

        return eventDate.ToString("dd MMM yyyy", CultureInfo.InvariantCulture);
    }

    public string GetEventTypeClass(Rebel.Domain.Enums.EventType type)
    {
        return type switch
        {
            Rebel.Domain.Enums.EventType.DJNight => "event-type-dj",
            Rebel.Domain.Enums.EventType.LiveMusic => "event-type-live",
            Rebel.Domain.Enums.EventType.BeerTasting => "event-type-beer",
            Rebel.Domain.Enums.EventType.SpecialEvent => "event-type-special",
            Rebel.Domain.Enums.EventType.AcousticNight => "event-type-acoustic",
            _ => "event-type-default"
        };
    }

    public string GetEventTypeLabel(Rebel.Domain.Enums.EventType type)
    {
        return type switch
        {
            Rebel.Domain.Enums.EventType.DJNight => "DJ NIGHT",
            Rebel.Domain.Enums.EventType.LiveMusic => "LIVE MUSIC",
            Rebel.Domain.Enums.EventType.BeerTasting => "BEER TASTING",
            Rebel.Domain.Enums.EventType.SpecialEvent => "SPECIAL EVENT",
            Rebel.Domain.Enums.EventType.AcousticNight => "ACOUSTIC NIGHT",
            _ => type.ToString().ToUpperInvariant()
        };
    }

    public string FormatTime(TimeSpan time)
    {
        return time.ToString(@"hh\:mm");
    }
}

<section class="rebel-events-page">

    <!-- HERO -->
    <div class="rebel-events-hero">
        <div class="events-hero-glow events-hero-glow-one"></div>
        <div class="events-hero-glow events-hero-glow-two"></div>
        <div class="events-hero-rings"></div>
        <div class="events-hero-scratch events-hero-scratch-one"></div>
        <div class="events-hero-scratch events-hero-scratch-two"></div>

        <div class="container position-relative">
            <div class="events-hero-content">

                <div class="events-eyebrow">
                    <span></span>
                    REBEL REBEL EVENTS
                </div>

                <h1 class="events-main-title">
                    <span class="events-title-solid">
                        <span>THE</span>
                        <span class="events-title-night">NIGHT</span>
                    </span>

                    <span class="events-title-outline">
                        <span>STARTS</span>
                        <span class="events-title-here">HERE.</span>
                    </span>
                </h1>

                <p class="events-hero-description">
                    Live music, loud nights, cold beer and the kind of stories
                    that should probably stay at the pub.
                </p>

                <div class="events-hero-info">
                    <div class="hero-info-item hero-event-count">
                        <strong>@events.Count</strong>
                        <span>UPCOMING EVENTS</span>
                    </div>

                    @if (nextEvent != null)
                    {
                        <div class="hero-info-divider"></div>

                        <div class="hero-info-item hero-next-event">
                            <strong>@FormatEventDate(nextEvent.Date)</strong>
                            <span>NEXT: @nextEvent.Title</span>
                        </div>
                    }
                </div>

                <a href="#upcoming-events" class="events-scroll-link">
                    EXPLORE THE LINEUP
                    <span>↓</span>
                </a>

            </div>
        </div>
    </div>

    <!-- EVENT CAROUSEL -->
    <div class="rebel-events-content" id="upcoming-events">
        <div class="container">

            <div class="events-section-header">
                <div class="events-section-heading">
                    <span class="events-small-label">DON'T MISS OUT</span>

                    <h2>
                        <span>UPCOMING</span>
                        <span class="events-section-title-accent">NIGHTS</span>
                    </h2>
                </div>

                <p>
                    One event in the spotlight. No endless wall of cards.
                    Pick the night and claim your table.
                </p>
            </div>

            @if (events.Any())
            {
                <div id="rebel3dEvents"
                     class="rebel-3d-carousel"
                     tabindex="0"
                     role="region"
                     aria-label="Upcoming events carousel">

                    <div class="rebel-3d-stage">
                        <div class="rebel-3d-track">
                            @for (var i = 0; i < events.Count; i++)
                            {
                                var e = events[i];

                                <article class="rebel-3d-slide @GetEventTypeClass(e.EventType)"
                                         data-index="@i"
                                         aria-hidden="@(i == 0 ? "false" : "true")">

                                    <div class="rebel-3d-poster">
                                        @if (!string.IsNullOrWhiteSpace(e.ImageUrl))
                                        {
                                            <img src="@e.ImageUrl"
                                                 class="rebel-3d-image"
                                                 alt="@e.Title"
                                                 draggable="false" />
                                        }
                                        else
                                        {
                                            <div class="rebel-3d-placeholder">
                                                <span>REBEL REBEL</span>
                                                <strong>NO POSTER.<br />STILL A GOOD NIGHT.</strong>
                                            </div>
                                        }

                                        <div class="rebel-3d-shade"></div>
                                        <div class="rebel-3d-grain"></div>
                                        <div class="rebel-3d-flare"></div>

                                        <div class="rebel-3d-date">
                                            <span>@e.Date.ToString("dd")</span>
                                            <small>@e.Date.ToString("MMM", CultureInfo.InvariantCulture)</small>
                                        </div>

                                        <span class="rebel-3d-type">
                                            @GetEventTypeLabel(e.EventType)
                                        </span>

                                        <div class="rebel-3d-number">
                                            @((i + 1).ToString("00")) / @(events.Count.ToString("00"))
                                        </div>

                                        <div class="rebel-3d-content">
                                            <span class="rebel-3d-kicker">
                                                @FormatEventDate(e.Date)
                                            </span>

                                            <h3>@e.Title</h3>

                                            <div class="rebel-3d-meta">
                                                <span>
                                                    @e.Date.ToString(
                                                    "dddd, dd MMMM yyyy",
                                                                                        CultureInfo.InvariantCulture)
                                        </span>

                                        @if (e.StartTime.HasValue)
                                            {
                                                <span class="rebel-3d-time">
                                                    @FormatTime(e.StartTime.Value)
                                                </span>
                                            }
                                    </div>

                                    <p>
                                        @(string.IsNullOrWhiteSpace(e.Description)
                                                                                ? "One more reason to cancel your quiet night at home."
                                                                                : e.Description)
                                    </p>

                                        <div class="rebel-3d-actions">
                                            <a asp-controller="Reservations"
                                               asp-action="Create"
                                               asp-route-eventId="@e.Id"
                                               class="event-reserve-button">
                                                RESERVE A TABLE
                                            </a>

                                            <a asp-controller="Events"
                                               asp-action="Details"
                                               asp-route-id="@e.Id"
                                               class="event-details-link">
                                                VIEW EVENT
                                                <span>↗</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </article>
                                                }
                    </div>

                    @if (events.Count > 1)
                    {
                        <button type="button"
                                class="rebel-3d-arrow rebel-3d-arrow-prev"
                                data-rebel-prev
                                aria-label="Previous event">
                            ←
                        </button>

                        <button type="button"
                                class="rebel-3d-arrow rebel-3d-arrow-next"
                                data-rebel-next
                                aria-label="Next event">
                            →
                        </button>
                    }
                </div>

                @if (events.Count > 1)
                {
                    <div class="rebel-3d-controls">
                        <span class="rebel-3d-instruction">
                            DRAG WITH THE MOUSE / SWIPE
                        </span>

                        <div class="rebel-3d-dots" aria-label="Choose an event">
                            @for (var i = 0; i < events.Count; i++)
                            {
                                <button type="button"
                                        class="rebel-3d-dot @(i == 0 ? "is-active" : "")"
                                        data-rebel-dot="@i"
                                        aria-label="Go to event @(i + 1)"
                                        aria-current="@(i == 0 ? "true" : "false")">
                                </button>
                            }
                        </div>

                        <span class="rebel-3d-status" aria-live="polite">
                            01 / @(events.Count.ToString("00"))
                        </span>
                    </div>
                }
            </div>
                        }
                        else
            {
                <div class="events-empty-state">
                    <span>CURRENTLY QUIET</span>
                    <h3>No upcoming events right now.</h3>
                    <p>
                        The speakers are resting, but not for long.
                        Check back soon for new nights, live sets and special events.
                    </p>

                    <a asp-controller="Home"
                       asp-action="Index"
                       class="empty-events-button">
                        BACK TO THE PUB
                    </a>
                </div>
            }

            <div class="events-final-cta">
                <div>
                    <span>WALK-INS ARE BRAVE.</span>
                    <h3>Reservations are smarter.</h3>
                </div>

                <a asp-controller="Reservations"
                   asp-action="Create"
                   class="events-general-reserve">
                    RESERVE A TABLE
                </a>
            </div>

        </div>
    </div>

</section>

<style>
    .rebel-events-page {
        --rebel-yellow: #ffb000;
        --rebel-black: #070707;
        --rebel-panel: #111111;
        background: radial-gradient(circle at 10% 20%, rgba(255, 176, 0, 0.055), transparent 30%), var(--rebel-black);
        color: #ffffff;
        overflow: hidden;
    }

    /* HERO */
    .rebel-events-hero {
        position: relative;
        min-height: 610px;
        display: flex;
        align-items: center;
        background: linear-gradient(90deg, rgba(5, 5, 5, 0.99) 0%, rgba(5, 5, 5, 0.91) 50%, rgba(5, 5, 5, 0.62) 100%), linear-gradient(135deg, #121212 0%, #050505 100%);
        border-bottom: 1px solid rgba(255, 255, 255, 0.075);
        isolation: isolate;
    }

        .rebel-events-hero::after {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -1;
            background: repeating-linear-gradient( -45deg, transparent 0, transparent 56px, rgba(255, 255, 255, 0.012) 57px, rgba(255, 255, 255, 0.012) 58px );
            pointer-events: none;
        }

    .events-hero-content {
        position: relative;
        z-index: 3;
        max-width: 930px;
        padding: 95px 0 88px;
    }

    .events-eyebrow {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 28px;
        color: var(--rebel-yellow);
        font-size: 0.75rem;
        font-weight: 900;
        letter-spacing: 0.28em;
        transform: translateX(-4px) rotate(-0.6deg);
        transform-origin: left center;
    }

        .events-eyebrow > span {
            width: 60px;
            height: 3px;
            background: var(--rebel-yellow);
            box-shadow: 0 0 16px rgba(255, 176, 0, 0.38);
            transform: rotate(-2deg);
        }

    .events-main-title {
        position: relative;
        margin: 0;
        max-width: 940px;
        font-family: "Arial Black", "Segoe UI", Arial, sans-serif;
        font-size: clamp(4rem, 8vw, 7.2rem);
        line-height: 0.86;
        font-weight: 900;
        letter-spacing: -0.03em;
        text-transform: uppercase;
    }

    .events-title-solid,
    .events-title-outline {
        display: flex;
        align-items: baseline;
        width: max-content;
        max-width: 100%;
        white-space: nowrap;
    }

    .events-title-solid {
        gap: 0.18em;
        color: #ffffff;
        transform: rotate(-0.75deg);
        transform-origin: left center;
    }

    .events-title-outline {
        gap: 0.14em;
        margin-top: 11px;
        color: transparent;
        font-size: 0.86em;
        letter-spacing: -0.012em;
        -webkit-text-stroke: 2.7px var(--rebel-yellow);
        text-shadow: 0 0 20px rgba(255, 176, 0, 0.16), 0 0 42px rgba(255, 176, 0, 0.07);
        transform: translateX(8px) rotate(0.6deg);
        transform-origin: left center;
    }

    .events-title-night {
        display: inline-block;
        transform: translateY(-4px) rotate(0.5deg);
    }

    .events-title-here {
        display: inline-block;
        transform: translateY(-2px) rotate(0.6deg);
    }

    .events-main-title::after {
        content: "";
        position: absolute;
        left: -20px;
        bottom: 3px;
        z-index: -1;
        width: 118px;
        height: 8px;
        background: var(--rebel-yellow);
        transform: rotate(-5deg);
        opacity: 0.88;
    }

    .events-hero-description {
        max-width: 630px;
        margin: 36px 0 0 6px;
        color: #aaaaaa;
        font-size: 1.06rem;
        line-height: 1.8;
    }

    .events-hero-info {
        display: flex;
        align-items: center;
        gap: 28px;
        margin-top: 39px;
        transform: rotate(-0.15deg);
        transform-origin: left center;
    }

    .hero-info-item {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .hero-info-item strong {
            color: #ffffff;
            font-size: 1.15rem;
            font-weight: 900;
            text-transform: uppercase;
        }

        .hero-info-item span {
            color: #777777;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

    .hero-event-count strong {
        color: var(--rebel-yellow);
        font-size: 2.1rem;
        line-height: 1;
    }

    .hero-info-divider {
        width: 1px;
        height: 45px;
        background: rgba(255, 255, 255, 0.14);
    }

    .hero-next-event span {
        max-width: 380px;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .events-scroll-link {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        margin-top: 43px;
        color: #ffffff;
        font-size: 0.75rem;
        font-weight: 900;
        letter-spacing: 0.15em;
        text-decoration: none;
        transition: color 0.25s ease;
    }

        .events-scroll-link > span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 35px;
            height: 35px;
            color: var(--rebel-yellow);
            border: 1px solid rgba(255, 176, 0, 0.65);
            border-radius: 50%;
            transition: transform 0.25s ease, background 0.25s ease;
        }

        .events-scroll-link:hover {
            color: var(--rebel-yellow);
        }

            .events-scroll-link:hover > span {
                transform: translateY(4px);
                background: rgba(255, 176, 0, 0.1);
            }

    .events-hero-glow {
        position: absolute;
        z-index: -1;
        border-radius: 50%;
        pointer-events: none;
    }

    .events-hero-glow-one {
        top: -170px;
        right: -100px;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(255, 176, 0, 0.17), rgba(255, 176, 0, 0.035) 44%, transparent 70%);
    }

    .events-hero-glow-two {
        bottom: -150px;
        left: 15%;
        width: 320px;
        height: 320px;
        background: radial-gradient(circle, rgba(255, 70, 35, 0.11), transparent 68%);
    }

    .events-hero-rings {
        position: absolute;
        top: 50%;
        right: 3%;
        z-index: -1;
        width: 350px;
        height: 350px;
        border: 1px solid rgba(255, 176, 0, 0.08);
        border-radius: 50%;
        transform: translateY(-50%) rotate(12deg);
    }

        .events-hero-rings::before,
        .events-hero-rings::after {
            content: "";
            position: absolute;
            border: 1px solid rgba(255, 176, 0, 0.065);
            border-radius: 50%;
        }

        .events-hero-rings::before {
            inset: 48px;
        }

        .events-hero-rings::after {
            inset: 102px;
        }

    .events-hero-scratch {
        position: absolute;
        z-index: -1;
        height: 3px;
        background: rgba(255, 176, 0, 0.16);
        pointer-events: none;
    }

    .events-hero-scratch-one {
        top: 25%;
        right: 11%;
        width: 210px;
        transform: rotate(-18deg);
        box-shadow: 0 11px 0 rgba(255, 176, 0, 0.07), 0 22px 0 rgba(255, 176, 0, 0.03);
    }

    .events-hero-scratch-two {
        left: 4%;
        bottom: 13%;
        width: 125px;
        height: 2px;
        transform: rotate(9deg);
        opacity: 0.55;
    }

    /* EVENTS SECTION */
    .rebel-events-content {
        padding: 105px 0 95px;
    }

    .events-section-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 45px;
        margin-bottom: 48px;
    }

    .events-small-label {
        display: block;
        margin: 0 0 10px 4px;
        color: var(--rebel-yellow);
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 0.22em;
        transform: rotate(-0.7deg);
        transform-origin: left center;
    }

    .events-section-header h2 {
        position: relative;
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.2em;
        margin: 0;
        color: #ffffff;
        font-family: "Arial Black", "Segoe UI", Arial, sans-serif;
        font-size: clamp(2.65rem, 5vw, 4.25rem);
        line-height: 1;
        font-weight: 900;
        letter-spacing: -0.02em;
    }

        .events-section-header h2::before {
            content: "";
            position: absolute;
            top: 52%;
            left: -14px;
            width: 6px;
            height: 46px;
            background: var(--rebel-yellow);
            border-radius: 2px;
            transform: translateY(-50%) rotate(8deg);
        }

    .events-section-title-accent {
        position: relative;
        display: inline-block;
        transform: translateY(5px) rotate(-1.2deg);
    }

        .events-section-title-accent::after {
            content: "";
            position: absolute;
            right: -4%;
            bottom: -7px;
            left: 1%;
            height: 5px;
            background: var(--rebel-yellow);
            transform: rotate(-1.5deg);
            box-shadow: 18px 8px 0 -1px rgba(255, 176, 0, 0.3);
        }

    .events-section-header p {
        max-width: 440px;
        margin: 0;
        color: #858585;
        line-height: 1.75;
        transform: translateY(-3px) rotate(0.15deg);
    }

    /* 3D EVENT CAROUSEL */
    .rebel-3d-carousel {
        --slide-width: min(900px, 72vw);
        position: relative;
        outline: none;
        user-select: none;
        -webkit-user-select: none;
        touch-action: pan-y;
    }

    .rebel-3d-stage {
        position: relative;
        height: 610px;
        perspective: 1650px;
        perspective-origin: 50% 46%;
        cursor: grab;
    }

    .rebel-3d-carousel.is-dragging .rebel-3d-stage {
        cursor: grabbing;
    }

    .rebel-3d-track {
        position: absolute;
        inset: 0;
        transform-style: preserve-3d;
    }

    .rebel-3d-slide {
        --event-accent: var(--rebel-yellow);
        position: absolute;
        top: 50%;
        left: 50%;
        width: var(--slide-width);
        height: 535px;
        opacity: 0;
        transform-style: preserve-3d;
        will-change: transform, opacity, filter;
        transition: transform 0.72s cubic-bezier(0.2, 0.78, 0.22, 1), opacity 0.42s ease, filter 0.42s ease;
        pointer-events: none;
    }

    .rebel-3d-carousel.is-dragging .rebel-3d-slide {
        transition: none;
    }

    .rebel-3d-slide.is-visible {
        pointer-events: auto;
    }

    .event-type-live {
        --event-accent: #ff4d35;
    }

    .event-type-beer {
        --event-accent: #d99b22;
    }

    .event-type-special {
        --event-accent: #8855ff;
    }

    .event-type-acoustic {
        --event-accent: #e0ddd4;
    }

    .rebel-3d-poster {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #121212;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 30px 8px 30px 8px;
        box-shadow: 0 42px 90px rgba(0, 0, 0, 0.56), 0 12px 25px rgba(0, 0, 0, 0.35);
        transform-style: preserve-3d;
        isolation: isolate;
    }

    .rebel-3d-slide.is-active .rebel-3d-poster {
        border-color: color-mix(in srgb, var(--event-accent) 42%, rgba(255, 255, 255, 0.14));
        box-shadow: 0 50px 110px rgba(0, 0, 0, 0.65), 0 0 45px color-mix(in srgb, var(--event-accent) 12%, transparent);
    }

    .rebel-3d-poster::before {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        z-index: 7;
        width: 7px;
        background: linear-gradient( to bottom, transparent, color-mix(in srgb, var(--event-accent) 80%, white 5%), transparent );
        opacity: 0.75;
        transform: translateZ(28px);
        pointer-events: none;
    }

    .rebel-3d-poster::after {
        content: "";
        position: absolute;
        right: 8%;
        bottom: -7px;
        z-index: 8;
        width: 180px;
        height: 8px;
        background: var(--event-accent);
        box-shadow: 38px -15px 0 -3px rgba(255, 255, 255, 0.16);
        transform: rotate(-1.8deg) translateZ(34px);
        pointer-events: none;
    }

    .rebel-3d-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
        transform: scale(1.025) translateZ(0);
        transition: transform 0.75s ease, filter 0.5s ease;
    }

    .rebel-3d-slide.is-active .rebel-3d-image {
        transform: scale(1.065) translateZ(0);
        filter: contrast(1.06) saturate(1.04);
    }

    .rebel-3d-placeholder {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-end;
        width: 100%;
        height: 100%;
        padding: 58px;
        background: radial-gradient(circle at 30% 30%, rgba(255, 176, 0, 0.15), transparent 31%), repeating-linear-gradient(-45deg, #111111, #111111 20px, #161616 20px, #161616 40px);
    }

        .rebel-3d-placeholder span {
            margin-bottom: 10px;
            color: var(--rebel-yellow);
            font-size: 0.7rem;
            font-weight: 900;
            letter-spacing: 0.25em;
        }

        .rebel-3d-placeholder strong {
            max-width: 620px;
            color: #ffffff;
            font-family: "Arial Black", "Segoe UI", Arial, sans-serif;
            font-size: clamp(2.5rem, 5vw, 5rem);
            line-height: 0.92;
            letter-spacing: -0.04em;
        }

    .rebel-3d-shade {
        position: absolute;
        inset: 0;
        z-index: 2;
